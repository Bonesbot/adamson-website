---
// src/components/IdxAreaShowcase.astro
//
// Drops a Saved-Link / Showcase widget under each area page's AEO content.
// This is the "Supplement" pattern: your custom Astro AEO copy + Supabase
// stats own the SEO/AEO surface, and this widget shows live current
// inventory below it for the visitor.
//
// USAGE in src/pages/areas/longboat-key.astro:
//   ---
//   import IdxAreaShowcase from '@/components/IdxAreaShowcase.astro';
//   ---
//   <IdxAreaShowcase
//     widgetId="98765"
//     areaName="Longboat Key"
//     viewAllUrl="/idx/results?ccz=city&city[]=Longboat+Key"
//   />
//
// To create a Saved-Link Showcase widget per area:
//   1. IDX dashboard → Saved Links → Add Saved Link → filter to that area
//      (city, polygon, MLS area code, etc.) → save.
//   2. IDX dashboard → Widgets → Add Widget → choose "Showcase" or
//      "Map Showcase" → bind it to the Saved Link → save.
//   3. Copy the widget's numeric ID into widgetId.

interface Props {
  widgetId: string;
  areaName: string;
  /** Optional: where the "View all" CTA points. Should be an /idx/... URL. */
  viewAllUrl?: string;
  /** Optional sub-heading; defaults to "Active Listings". */
  label?: string;
  /** Where the off-market CTA points. */
  offMarketUrl?: string;
  /** Render the prominent off-market band around the feed. */
  showOffMarketCta?: boolean;
}

const {
  widgetId,
  areaName,
  viewAllUrl,
  label = 'Active Listings',
  offMarketUrl = '/find-my-dream-home',
  showOffMarketCta = true,
} = Astro.props;
---

<section class="section dark-section idx-area-showcase">
  <div class="container">
    <div class="text-center mb-10">
      <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">
        {label}
      </p>
      <h2 class="accent-underline-center">
        Currently for Sale in {areaName}
      </h2>
      <p class="text-white/60 text-sm max-w-xl mx-auto mt-3">
        Live from Stellar MLS. Updated continuously.
      </p>
      {showOffMarketCta && (
        <p class="text-sm max-w-xl mx-auto mt-2 text-white/70">
          Not seeing it here?
          <a href={offMarketUrl} class="text-[var(--color-gold)] hover:text-[var(--color-gold-light)] font-semibold underline underline-offset-4 ml-1">
            Search off-market properties &rarr;
          </a>
        </p>
      )}
    </div>

    <div class="idx-showcase-frame">
      <div id={`idxwidgetsrc-${widgetId}`}></div>
      <!-- NOTE: no `defer` — IDX Broker widget scripts inject their markup via
           document.write, which browsers silently discard for deferred scripts.
           This must execute inline, at this exact spot, during HTML parsing. -->
      <script
        is:inline
        type="text/javascript"
        charset="UTF-8"
        id={`idxwidgetsrc-script-${widgetId}`}
        src={`https://adamsonfl.idxbroker.com/idx/widgets/${widgetId}`}
      ></script>
      <!-- Keep click-throughs on adamsonfl.com: the widget emits links to the raw
           adamsonfl.idxbroker.com subdomain, which bypasses the Netlify /idx/* proxy
           and therefore the Dynamic Wrapper (unbranded page, Cloudflare challenge on
           mobile). Rewrite shadow-DOM hrefs to same-origin; the proxy serves the
           identical path wrapped in the site chrome. -->
      <script is:inline>
        (function () {
          var IDX_HOST = 'adamsonfl.idxbroker.com';
          var pending = null;
          function rewrite(root) {
            root.querySelectorAll('a[href*="' + IDX_HOST + '/idx/"]').forEach(function (a) {
              try {
                var u = new URL(a.href);
                if (u.host === IDX_HOST) {
                  u.protocol = 'https:';
                  u.host = window.location.host;
                  a.href = u.toString();
                }
              } catch (e) { /* leave link untouched */ }
            });
          }
          function arm() {
            var armed = false;
            document.querySelectorAll('*').forEach(function (el) {
              if (el.tagName.indexOf('IDX-') === 0 && el.shadowRoot && !el.__idxLinkFix) {
                el.__idxLinkFix = true;
                armed = true;
                var root = el.shadowRoot;
                rewrite(root);
                new MutationObserver(function () {
                  if (pending) return;
                  pending = setTimeout(function () { pending = null; rewrite(root); }, 300);
                }).observe(root, { childList: true, subtree: true });
              }
            });
            return armed;
          }
          var tries = 0;
          var timer = setInterval(function () {
            if (arm() || ++tries > 60) clearInterval(timer);
          }, 500);
        })();
      </script>
    </div>

    {viewAllUrl && (
      <div class="text-center mt-10">
        <a
          href={viewAllUrl}
          class="inline-flex items-center justify-center font-accent uppercase tracking-wider transition-all duration-200 rounded bg-[var(--color-gold)] text-black hover:bg-[var(--color-gold-light)] font-semibold text-sm px-8 py-4"
        >
          View All {areaName} Listings
        </a>
      </div>
    )}

    {showOffMarketCta && (
      <aside class="idx-offmarket-band mt-10" aria-label="Off-market properties">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
          <div>
            <h3 class="font-display text-xl md:text-2xl text-white m-0 mb-2">
              Don't see the home you want?
            </h3>
            <p class="text-white/70 text-sm md:text-base m-0 max-w-2xl">
              Many of {areaName}'s finest properties trade quietly — before they ever reach the MLS.
              Tell Ryan what you're looking for and get matched against off-market and pre-list opportunities.
            </p>
          </div>
          <a
            href={offMarketUrl}
            class="inline-flex items-center justify-center font-accent uppercase tracking-wider transition-all duration-200 rounded bg-[var(--color-gold)] text-black hover:bg-[var(--color-gold-light)] font-semibold text-sm px-8 py-4 whitespace-nowrap flex-shrink-0"
          >
            Find Off-Market Properties
          </a>
        </div>
      </aside>
    )}
  </div>
</section>

<style>
  .idx-area-showcase {
    /* Inherits .section + .dark-section from your global styles */
  }

  .idx-showcase-frame {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    padding: 1rem;
    min-height: 300px;
  }

  .idx-offmarket-band {
    background: linear-gradient(135deg, rgba(197, 165, 90, 0.12), rgba(197, 165, 90, 0.04));
    border: 1px solid rgba(197, 165, 90, 0.35);
    border-radius: 8px;
    padding: 1.75rem 2rem;
  }
</style>

---
/**
 * Area Card — Used on homepage and /areas index
 * Links to full area market page. Designed for luxury aesthetic.
 */
interface Props {
  name: string;
  slug: string;
  tagline: string;
  imageSrc?: string;
  medianPrice?: string;
}

const {
  name,
  slug,
  tagline,
  imageSrc = '/images/placeholder-area.jpg',
  medianPrice,
} = Astro.props;
---

<a
  href={`/areas/${slug}`}
  class="group block relative overflow-hidden rounded-lg aspect-[4/5] md:aspect-[3/4]"
>
  <!-- Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
    style={`background-image: url('${imageSrc}'); background-color: var(--color-charcoal);`}
  />

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />

  <!-- Content -->
  <div class="absolute bottom-0 left-0 right-0 p-6">
    <h3 class="font-display text-2xl font-bold text-white mb-1 group-hover:text-[var(--color-gold-light)] transition-colors">
      {name}
    </h3>
    <p class="text-sm text-white/70 mb-2">{tagline}</p>
    {medianPrice && (
      <p class="font-accent text-xs uppercase tracking-wider text-[var(--color-gold)]">
        From {medianPrice}
      </p>
    )}
  </div>
</a>

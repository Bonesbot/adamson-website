---
/**
 * ProjectMap — PLACEHOLDER for the Mapbox interactive map (spec §9).
 *
 * Today: renders a static panel with each project listed and color-coded
 * by area. Pin coordinates from projects.json (lat/lng — currently null
 * for most, will populate when Ryan fills in addresses).
 *
 * To wire Mapbox: replace the inner panel with a Mapbox GL JS instance,
 * add custom marker SVGs colored per area, and pass the same pins[] array.
 */
interface Pin {
  slug: string;
  name: string;
  area: string;
  island?: string | null;
  status?: string;
  lat?: number | null;
  lng?: number | null;
}

interface Props {
  pins: Pin[];
}

const { pins } = Astro.props;

const colorFor = (area: string, island: string | null | undefined) => {
  if (area === 'downtown-sarasota') return 'var(--color-cbgl-blue-light)';
  if (island === 'lido-key') return 'var(--color-gold)';
  if (island === 'longboat-key') return '#6FB1FC';
  if (island === 'siesta-key') return '#E8D5A3';
  return 'var(--color-text-light)';
};
---

<section class="section dark-section">
  <div class="container">
    <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">Find your fit</p>
    <h2 class="accent-underline mb-8">Map of Active Projects</h2>

    <div class="bg-black border border-white/10 rounded-lg p-8">
      <!-- Map placeholder — replace with Mapbox GL JS instance -->
      <div class="aspect-[16/9] bg-[var(--color-dark)] rounded flex items-center justify-center mb-6 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-cbgl-blue)]/20 via-transparent to-[var(--color-gold)]/10" />
        <div class="relative z-10 text-center">
          <svg class="w-16 h-16 text-white/20 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          <p class="font-accent text-xs uppercase tracking-[0.2em] text-white/40">
            Mapbox interactive map &mdash; placeholder
          </p>
          <p class="text-xs text-white/30 mt-1">
            Pins below will plot to map coordinates once project lat/lng filled in.
          </p>
        </div>
      </div>

      <!-- Pin list — accessible fallback, also serves as map legend -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {pins.map((p) => (
          <a href={`/new-construction/${p.slug}`} class="flex items-start gap-3 p-3 rounded hover:bg-[var(--color-dark)] transition-colors group">
            <span
              class="mt-1 w-3 h-3 rounded-full flex-shrink-0"
              style={`background-color: ${colorFor(p.area, p.island)};`}
              aria-hidden="true"
            />
            <div class="min-w-0">
              <p class="font-display text-sm font-semibold text-white group-hover:text-[var(--color-gold)] truncate">
                {p.name}
              </p>
              <p class="font-accent text-[10px] uppercase tracking-wider text-white/50 truncate">
                {p.area === 'downtown-sarasota' ? 'Downtown Sarasota' : (p.island || 'Barrier Islands').replace(/-/g, ' ')}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

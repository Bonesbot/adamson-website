---
/**
 * ProjectMap — interactive Leaflet map of active projects.
 * Carto Voyager tiles + custom teardrop pins (SRQmap treatment),
 * color-coded by area. Pin list below doubles as legend + a11y fallback.
 */
interface Pin {
  slug: string;
  name: string;
  area: string;
  island?: string | null;
  status?: string;
  price_range?: string;
  lat?: number | null;
  lng?: number | null;
}

interface Props {
  pins: Pin[];
  /** Map center + zoom. Defaults frame Golden Gate Point → Quay corridor. */
  center?: [number, number];
  zoom?: number;
}

const { pins, center = [27.325, -82.55], zoom = 13 } = Astro.props;

const colorFor = (area: string, island: string | null | undefined) => {
  if (island === 'lido-key') return '#C5A55A';
  if (island === 'longboat-key') return '#6FB1FC';
  if (island === 'siesta-key') return '#E8D5A3';
  return '#2E86AB';
};

const mapPins = pins
  .filter((p) => p.lat && p.lng)
  .map((p) => ({ ...p, color: colorFor(p.area, p.island) }));

const areaLabel = (p: Pin) =>
  p.area === 'downtown-sarasota'
    ? 'Downtown Sarasota'
    : (p.island || 'barrier islands').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
---

<section class="section dark-section">
  <div class="container">
    <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">Find your fit</p>
    <h2 class="accent-underline mb-8">Map of Active Projects</h2>

    <div class="bg-black border border-white/10 rounded-lg overflow-hidden">
      <div id="nc-project-map" class="w-full h-[420px] md:h-[520px]" aria-label="Map of Sarasota luxury new-construction projects"></div>

      <!-- Pin list — legend + accessible fallback -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 p-6">
        {pins.map((p) => (
          <a href={`/new-construction/${p.slug}`} data-map-pin={p.slug} class="flex items-start gap-3 p-3 rounded hover:bg-[var(--color-dark)] transition-colors group">
            <span
              class="mt-1 w-3 h-3 rounded-full flex-shrink-0"
              style={`background-color: ${colorFor(p.area, p.island)};`}
              aria-hidden="true"
            />
            <div class="min-w-0">
              <p class="font-display text-sm font-semibold text-white group-hover:text-[var(--color-gold)] truncate">
                {p.name}
              </p>
              <p class="font-accent text-[10px] uppercase tracking-wider text-white/50 truncate">
                {areaLabel(p)}{p.price_range ? ` · ${p.price_range}` : ''}
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style is:global>
  #nc-project-map { background: #AEC9D6; }
  #nc-project-map .leaflet-div-icon { background: transparent; border: none; }
  .nc-pin { cursor: pointer; width: 32px; height: 32px; position: relative; transition: transform .15s ease; }
  .nc-pin .body {
    width: 32px; height: 32px; border-radius: 50% 50% 50% 2px; transform: rotate(45deg);
    display: grid; place-items: center;
    box-shadow: 0 5px 12px -4px rgba(10,42,64,.6); border: 2px solid rgba(255,255,255,.92);
  }
  .nc-pin .body svg { transform: rotate(-45deg); width: 15px; height: 15px; stroke: #fff; fill: none; stroke-width: 2; }
  .nc-pin:hover { transform: translateY(-3px) scale(1.06); }
  .nc-popup .leaflet-popup-content-wrapper {
    background: #0A0A0A; color: #fff; border: 1px solid rgba(197,165,90,.4);
    border-radius: 10px; box-shadow: 0 18px 50px -20px rgba(0,0,0,.8);
  }
  .nc-popup .leaflet-popup-content { margin: 14px 16px; font-family: 'Inter', system-ui, sans-serif; }
  .nc-popup .leaflet-popup-tip { background: #0A0A0A; border: 1px solid rgba(197,165,90,.4); }
  .nc-popup .nc-popup-name { font-family: 'Playfair Display', Georgia, serif; font-size: 17px; font-weight: 700; margin: 0 0 2px; color: #fff; }
  .nc-popup .nc-popup-meta { font-family: 'Montserrat', sans-serif; font-size: 10px; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.55); margin: 0 0 6px; }
  .nc-popup .nc-popup-price { font-family: 'Montserrat', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: #C5A55A; font-weight: 600; margin: 0 0 8px; }
  .nc-popup a.nc-popup-link { font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: #52a8ff; text-decoration: none; }
  .nc-popup a.nc-popup-link:hover { color: #C5A55A; }
  .nc-popup a.leaflet-popup-close-button { color: rgba(255,255,255,.6); }
</style>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script is:inline define:vars={{ mapPins, center, zoom }}>
  (function () {
    var el = document.getElementById('nc-project-map');
    if (!el || typeof L === 'undefined') return;
    var map = L.map('nc-project-map', { scrollWheelZoom: false, zoomControl: true }).setView(center, zoom);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>'
    }).addTo(map);

    var buildingSvg = '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/></svg>';
    var markers = {};

    mapPins.forEach(function (p) {
      var html = '<div class="nc-pin"><div class="body" style="background:' + p.color + '">' + buildingSvg + '</div></div>';
      var icon = L.divIcon({ html: html, iconSize: [32, 32], iconAnchor: [16, 32], popupAnchor: [0, -30] });
      var areaLabel = p.area === 'downtown-sarasota' ? 'Downtown Sarasota'
        : (p.island || 'Barrier Islands').replace(/-/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); });
      var popup = '<p class="nc-popup-name">' + p.name + '</p>'
        + '<p class="nc-popup-meta">' + areaLabel + (p.status ? ' &middot; ' + p.status : '') + '</p>'
        + (p.price_range ? '<p class="nc-popup-price">' + p.price_range + '</p>' : '')
        + '<a class="nc-popup-link" href="/new-construction/' + p.slug + '">View project &rarr;</a>';
      var m = L.marker([p.lat, p.lng], { icon: icon }).addTo(map)
        .bindPopup(popup, { className: 'nc-popup', maxWidth: 260 });
      markers[p.slug] = m;
    });

    if (mapPins.length > 1) {
      var group = L.featureGroup(Object.values(markers));
      map.fitBounds(group.getBounds().pad(0.25));
    }

    // Hovering a legend row opens the matching pin's popup
    document.querySelectorAll('[data-map-pin]').forEach(function (row) {
      row.addEventListener('mouseenter', function () {
        var m = markers[row.getAttribute('data-map-pin')];
        if (m) m.openPopup();
      });
    });
  })();
</script>

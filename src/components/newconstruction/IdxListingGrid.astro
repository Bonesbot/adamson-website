---
/**
 * IdxListingGrid — IDX Broker placeholder slot.
 *
 * Renders a clean, branded panel reserved for the live Stellar MLS feed.
 * TO WIRE (Ryan): drop the IDX Broker widget/saved-link embed inside the
 * <div data-idx-slot> below — one slot per page/section, each carries its
 * filter intent in data attributes so the right saved search plugs in.
 * The site already has /idx-wrapper/ and the Netlify proxy /idx/* →
 * adamsonfl.idxbroker.com.
 */
interface Props {
  /** MLS subdivision values (or BuildingName) intended for this feed. */
  subdivisions?: string[];
  /** Island slug (lido-key | longboat-key | siesta-key). */
  island?: string | null;
  /** ZIP codes intended for this feed. */
  zipCodes?: string[];
  /** Subdivision keyword filters. */
  subdivisionKeywords?: string[];
  /** Max listings the wired feed should render. */
  limit?: number;
  /** Heading shown above the grid. Pass empty string to hide. */
  heading?: string;
  /** Unique slot id so each IDX embed can be targeted. */
  slotId?: string;
}

const {
  subdivisions = [],
  island = null,
  zipCodes = [],
  subdivisionKeywords = [],
  limit = 6,
  heading = 'Currently Available',
  slotId = 'idx-default',
} = Astro.props;

const filterSummary = [
  island ? `Island: ${island}` : null,
  subdivisions.length ? `Subdivisions: ${subdivisions.join(', ')}` : null,
  zipCodes.length ? `ZIPs: ${zipCodes.join(', ')}` : null,
  subdivisionKeywords.length ? `Keywords: ${subdivisionKeywords.join(', ')}` : null,
].filter(Boolean).join(' · ');
---

{heading && <h3 class="font-display text-xl text-white mb-6">{heading}</h3>}

<!-- IDX-WIDGET-SLOT id={slotId} limit={limit} {filterSummary} — paste IDX Broker embed inside the div below -->
<div
  data-idx-slot={slotId}
  data-idx-island={island || undefined}
  data-idx-subdivisions={subdivisions.join('|') || undefined}
  data-idx-zips={zipCodes.join('|') || undefined}
  data-idx-limit={limit}
>
  <div class="bg-black border border-[var(--color-gold)]/30 rounded-lg p-8 md:p-10 text-center">
    <p class="font-accent text-xs uppercase tracking-[0.2em] text-[var(--color-gold)] mb-3">
      Live MLS availability
    </p>
    <p class="text-white/70 mb-2 max-w-xl mx-auto">
      Current listings for this search are curated directly from the Stellar MLS.
      Pre-construction inventory and developer releases often never reach the public feed.
    </p>
    <p class="text-white/40 text-sm mb-6">
      Ask Ryan for the real-time availability sheet &mdash; including unlisted developer inventory.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="#schedule" class="inline-block font-accent text-xs uppercase tracking-[0.15em] font-semibold bg-[var(--color-gold)] text-black px-6 py-3 rounded hover:bg-[var(--color-gold-light)] transition-colors">
        Get Current Availability
      </a>
      <a href="#vip" class="inline-block font-accent text-xs uppercase tracking-[0.15em] font-semibold border border-white/25 text-white px-6 py-3 rounded hover:border-[var(--color-gold)] hover:text-[var(--color-gold)] transition-colors">
        Join the VIP List
      </a>
    </div>
  </div>
</div>

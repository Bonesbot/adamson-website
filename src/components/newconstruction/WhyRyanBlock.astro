---
/**
 * WhyRyanBlock — 2-column block with headshot + bio focused on
 * new-construction expertise. Reservations strategy, pre-con contracts,
 * developer reputation knowledge.
 */
import Button from '@/components/ui/Button.astro';
---

<section class="section light-section">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <div class="aspect-[4/5] bg-[var(--color-charcoal)] rounded-lg overflow-hidden">
          <img
            src="/images/ryan-adamson.jpg"
            alt="Ryan Adamson, Adamson Group at Coldwell Banker Realty &mdash; St. Armands"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div>
        <p class="section-label text-[var(--color-cbgl-blue)] mb-3">Why Ryan</p>
        <h2 class="font-display text-3xl text-[var(--color-text)] mb-6 accent-underline">
          New construction is its own discipline
        </h2>
        <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
          Buying pre-construction is nothing like buying a resale. The price sheet is only the
          starting point &mdash; what actually determines your outcome is the deposit milestone
          schedule, the escrow language, the outside completion date, the finish-selection
          window, and the floor premium you're asked to pay versus what that line actually
          trades for at resale. Ryan tracks every active project in the Sarasota market &mdash;
          release calendars, absorption pace, developer track records &mdash; so his clients
          contract with leverage instead of a brochure.
        </p>
        <p class="text-[var(--color-text-muted)] leading-relaxed mb-6">
          The sales gallery represents the developer. Ryan represents you &mdash; at no cost,
          since the developer pays the buyer-side commission whether you bring an agent or not.
          The difference shows up in the contract terms and the unit you end up owning.
        </p>

        <ul class="space-y-2 mb-8 text-sm text-[var(--color-text-muted)]" role="list">
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-gold)]">&#10003;</span>
            Certified Luxury Home Marketing Specialist (CLHMS)
          </li>
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-gold)]">&#10003;</span>
            Million Dollar Guild Member
          </li>
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-gold)]">&#10003;</span>
            Coldwell Banker Global Luxury &mdash; St. Armands
          </li>
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-gold)]">&#10003;</span>
            5.0&#9733; Google rating from past clients
          </li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="#schedule" variant="primary">Talk to Ryan</Button>
          <Button href="/about" variant="outline">About Ryan</Button>
        </div>
      </div>
    </div>
  </div>
</section>

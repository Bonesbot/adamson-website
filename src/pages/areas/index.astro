---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AreaCard from '@/components/market/AreaCard.astro';
import { getAreas } from '@/lib/sanity';
import areasFallback from '@/data/areas.json';

const description = 'Explore luxury real estate markets across Sarasota\'s barrier islands — Longboat Key, Lido Key, Siesta Key, St. Armands, Bird Key, and greater Sarasota. Market data, pricing trends, and neighborhood guides.';

// Fallback JSON is the source of truth for which areas exist.
// Sanity entries with matching slugs override their content.
const sanityAreas = (await getAreas()) || [];
const sanityBySlug = new Map<string, any>(
  sanityAreas.filter((a: any) => a?.slug).map((a: any) => [a.slug, a])
);

const areas = areasFallback.areas.map((fallback) => {
  const sanity = sanityBySlug.get(fallback.slug);
  return {
    name: sanity?.name || fallback.name,
    slug: fallback.slug,
    tagline: sanity?.tagline || fallback.tagline,
    medianPrice: sanity?.marketStats?.medianPrice || fallback.marketStats.medianPrice,
    imageSrc: sanity?.cardImage || undefined,
  };
});

const jsonLd = {
  '@type': 'CollectionPage',
  name: 'Areas We Serve — Sarasota Luxury Real Estate',
  description: description,
  url: 'https://adamsonfl.com/areas',
};
---

<BaseLayout title="Areas We Serve" description={description} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="relative pt-32 pb-20">
    <div class="absolute inset-0" style="background-color: var(--color-black);" />
    <div class="relative z-10 container text-center">
      <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">
        Explore
      </p>
      <h1 class="font-display text-white mb-4">Areas We Serve</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        From exclusive barrier island estates to vibrant downtown waterfront living — discover Sarasota's most coveted communities.
      </p>
    </div>
  </section>

  <!-- Area Grid -->
  <section class="section dark-section">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area) => (
          <AreaCard
            name={area.name}
            slug={area.slug}
            tagline={area.tagline}
            medianPrice={area.medianPrice}
            imageSrc={area.imageSrc}
          />
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

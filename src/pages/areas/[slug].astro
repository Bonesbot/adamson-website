---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarketStats from '@/components/market/MarketStats.astro';
import DetailedMarketTable from '@/components/market/DetailedMarketTable.astro';
import AreaMarketSummary from '@/components/market/AreaMarketSummary.astro';
import FAQSchema from '@/components/seo/FAQSchema.astro';
import Button from '@/components/ui/Button.astro';
import { getAreas, getAreaBySlug } from '@/lib/sanity';
import areasFallback from '@/data/areas.json';

export async function getStaticPaths() {
  // Fallback JSON is the source of truth for WHICH areas exist.
  // Sanity is an editable content overlay — if it has an area with a
  // matching slug, that content wins; otherwise the fallback is used.
  // This ensures all 6 area pages always generate, regardless of what
  // (or whether) Sanity is populated.
  return areasFallback.areas.map((area: any) => ({
    params: { slug: area.slug },
  }));
}

const { slug } = Astro.params;

// Fetch area data — Sanity first (overlay), fallback to JSON.
let area: any = await getAreaBySlug(slug!);
if (!area || !area.slug) {
  area = areasFallback.areas.find((a) => a.slug === slug);
}

if (!area) {
  return Astro.redirect('/areas');
}

// Optional: detailed Sold+Pending stats from the Supabase pipeline.
// File is generated by scripts/fetch_area_summary.py and committed per area.
// Vite's glob import is resolved at build time, so missing files gracefully
// degrade (no detailed table shown for that slug).
let detailedStats: any = null;
const statsModules = import.meta.glob('../../data/*-stats.json', { eager: true }) as Record<string, any>;
for (const [path, mod] of Object.entries(statsModules)) {
  if (path.endsWith(`/${slug}-stats.json`)) {
    detailedStats = (mod as any).default ?? mod;
    break;
  }
}

// Headline price for meta description + WebPage JSON-LD schema.
// Prefer the live pipeline avg sold price (so AI crawlers see the same
// number rendered in the DetailedMarketTable). Fall back to the legacy
// median from areas.json / Sanity for areas not yet on the pipeline.
const headlinePrice =
  detailedStats?.metrics?.avgPrice
    ? `Average sold price: ${detailedStats.metrics.avgPrice}`
    : `Median home price: ${area.marketStats?.medianPrice || 'N/A'}`;

const description = `${area.name} real estate market data, pricing trends, and neighborhood guide. ${headlinePrice}. Expert insights from Ryan Adamson, Coldwell Banker St. Armands.`;

const jsonLd = [
  {
    '@type': 'Place',
    name: area.name,
    description: area.description,
    address: {
      '@type': 'PostalAddress',
      addressLocality: area.name,
      addressRegion: 'FL',
      postalCode: area.zipCodes?.[0] || '',
      addressCountry: 'US',
    },
  },
  {
    '@type': 'WebPage',
    name: `${area.name} Real Estate Market Guide`,
    description: description,
    url: `https://adamsonfl.com/areas/${area.slug}`,
    author: {
      '@type': 'RealEstateAgent',
      name: 'Ryan Adamson',
      worksFor: { '@type': 'Organization', name: 'Coldwell Banker Realty — St. Armands' },
    },
  },
];
---

<BaseLayout title={`${area.name} Real Estate`} description={description} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${area.heroImage || `/images/areas/${area.slug}.jpg`}'); background-color: var(--color-black);`}
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/90" />

    <div class="relative z-10 container">
      <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">
        Area Guide
      </p>
      <h1 class="font-display text-white mb-4">{area.name}</h1>
      <p class="text-lg text-white/70 max-w-2xl leading-relaxed">
        {area.tagline}
      </p>
    </div>
  </section>

  <!-- Overview -->
  <section class="section light-section">
    <div class="container-narrow">
      <h2 class="accent-underline mb-6">About {area.name}</h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed text-lg mb-8">
        {area.description}
      </p>

      {area.highlights && area.highlights.length > 0 && (
        <div class="flex flex-wrap gap-3">
          {area.highlights.map((highlight: string) => (
            <span class="inline-block bg-[var(--color-cbgl-blue)]/10 text-[var(--color-cbgl-blue)] font-accent text-xs uppercase tracking-wider px-4 py-2 rounded-full border border-[var(--color-cbgl-blue)]/20">
              {highlight}
            </span>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Market Stats — legacy placeholder block. Suppressed automatically
       whenever a detailedStats JSON file exists for this area, so the
       live MLS pipeline table becomes the single source of truth. -->
  {area.marketStats && !detailedStats && (
    <MarketStats areaName={area.name} stats={area.marketStats} />
  )}

  <!-- Detailed Sold + Pending Market Table (live MLS pipeline) -->
  {detailedStats && (
    <DetailedMarketTable areaName={area.name} stats={detailedStats} />
  )}

  <!-- Enriched AEO market summary — active inventory, price bands, sold comps -->
  {detailedStats && (detailedStats.active || detailedStats.sold) && (
    <AreaMarketSummary areaName={area.name} areaSlug={area.slug} stats={detailedStats} />
  )}

  <!-- FAQ Section -->
  {area.faqs && area.faqs.length > 0 && (
    <FAQSchema
      faqs={area.faqs}
      heading={`${area.name} Real Estate FAQ`}
    />
  )}

  <!-- CTA -->
  <section class="cbgl-section py-16">
    <div class="container text-center">
      <h2 class="font-display text-2xl text-white mb-4">
        Interested in {area.name}?
      </h2>
      <p class="text-white/70 mb-8 max-w-lg mx-auto">
        Get personalized market insights and property recommendations from a local expert.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Talk to Ryan
      </Button>
    </div>
  </section>

</BaseLayout>

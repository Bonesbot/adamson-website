---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarketStats from '@/components/market/MarketStats.astro';
import DetailedMarketTable from '@/components/market/DetailedMarketTable.astro';
import AreaMarketSummary from '@/components/market/AreaMarketSummary.astro';
import WaterfrontSegments from '@/components/market/WaterfrontSegments.astro';
import CondoTiersTable from '@/components/market/CondoTiersTable.astro';
import FAQSchema from '@/components/seo/FAQSchema.astro';
import IdxAreaShowcase from '@/components/IdxAreaShowcase.astro';
import Button from '@/components/ui/Button.astro';
import { getAreas, getAreaBySlug } from '@/lib/sanity';
import areasFallback from '@/data/areas.json';
import areaMedia from '@/data/area-media.json';

export async function getStaticPaths() {
  // Fallback JSON is the source of truth for WHICH areas exist.
  // Sanity is an editable content overlay — if it has an area with a
  // matching slug, that content wins; otherwise the fallback is used.
  // This ensures all 6 area pages always generate, regardless of what
  // (or whether) Sanity is populated.
  return areasFallback.areas.map((area: any) => ({
    params: { slug: area.slug },
  }));
}

const { slug } = Astro.params;
const media = (areaMedia as Record<string, any>)[slug!] || {};

// Fetch area data — Sanity first (overlay), fallback to JSON.
let area: any = await getAreaBySlug(slug!);
if (!area || !area.slug) {
  area = areasFallback.areas.find((a) => a.slug === slug);
}

if (!area) {
  return Astro.redirect('/areas');
}

// IDX Broker showcase widget — data-driven per area. The widget id lives in
// areas.json (fallback record) so it survives the Sanity content overlay.
const fallbackArea = areasFallback.areas.find((a: any) => a.slug === slug);
const idxWidgetId = (area as any).idxWidgetId || (fallbackArea as any)?.idxWidgetId || null;

// Optional: detailed Sold+Pending stats from the Supabase pipeline.
// File is generated by scripts/fetch_area_summary.py and committed per area.
// Vite's glob import is resolved at build time, so missing files gracefully
// degrade (no detailed table shown for that slug).
let detailedStats: any = null;
const statsModules = import.meta.glob('../../data/*-stats.json', { eager: true }) as Record<string, any>;
for (const [path, mod] of Object.entries(statsModules)) {
  if (path.endsWith(`/${slug}-stats.json`)) {
    detailedStats = (mod as any).default ?? mod;
    break;
  }
}

// Condo dues range (min / median / max monthly condo fee) -> Typical Condo Dues range bar.
const condoDues = detailedStats?.fees?.condoFeeRange ?? null;
const duesMedianPct = condoDues && condoDues.max > condoDues.min
  ? Math.round(((condoDues.median - condoDues.min) / (condoDues.max - condoDues.min)) * 100)
  : 0;
const duesPct = Math.min(94, Math.max(6, duesMedianPct));
const fmtUsd = (n: number) => `$${Math.round(n).toLocaleString("en-US")}`;

// Headline price for meta description + WebPage JSON-LD schema.
// Prefer the live pipeline avg sold price (so AI crawlers see the same
// number rendered in the DetailedMarketTable). Fall back to the legacy
// median from areas.json / Sanity for areas not yet on the pipeline.
// FAQ placeholder interpolation — answers in areas.json may embed tokens like
// {{active.medianPrice}} or {{asOf}}, resolved against the daily-refreshed
// pipeline stats at build time. Netlify rebuilds on every daily stats commit,
// so interpolated FAQ numbers can never drift from the tables on the same page.
// Any FAQ whose tokens cannot all be resolved is suppressed for that build
// rather than rendered with gaps.
function lookupPath(obj: any, path: string): any {
  return path.split('.').reduce((o: any, k: string) => (o == null ? undefined : o[k]), obj);
}

const asOf = detailedStats?.lastUpdated
  ? new Date(detailedStats.lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })
  : null;
const interpCtx = detailedStats ? { ...detailedStats, asOf } : null;

function interpolate(text: string): string | null {
  let ok = true;
  const out = text.replace(/\{\{\s*([\w.]+)\s*\}\}/g, (_m: string, p: string) => {
    const v = interpCtx ? lookupPath(interpCtx, p) : undefined;
    if (v === undefined || v === null || v === '') { ok = false; return ''; }
    return String(v);
  });
  return ok ? out : null;
}

const faqs = (area.faqs || [])
  .map((f: any) => ({ question: f.question, answer: interpolate(f.answer) }))
  .filter((f: any) => f.answer !== null) as { question: string; answer: string }[];

// Living FAQ — data-generated market answers prepended to the editorial FAQ (single FAQPage)
const livingFaqs = ((detailedStats?.marketQuestions) || []).map((q: any) => ({ question: q.q, answer: q.a })) as { question: string; answer: string }[];
const allFaqs = [...livingFaqs, ...faqs];

const headlinePrice =
  detailedStats?.metrics?.avgPrice
    ? `Average sold price: ${detailedStats.metrics.avgPrice}`
    : `Median home price: ${area.marketStats?.medianPrice || 'N/A'}`;

const description = `${area.name} real estate market data, pricing trends, and neighborhood guide. ${headlinePrice}. Expert insights from Ryan Adamson, Coldwell Banker St. Armands.`;

const jsonLd = [
  {
    '@type': 'Place',
    name: area.name,
    description: area.description,
    address: {
      '@type': 'PostalAddress',
      addressLocality: area.name,
      addressRegion: 'FL',
      postalCode: area.zipCodes?.[0] || '',
      addressCountry: 'US',
    },
  },
  {
    '@type': 'WebPage',
    name: `${area.name} Real Estate Market Guide`,
    description: description,
    url: `https://adamsonfl.com/areas/${area.slug}`,
    ...(detailedStats?.lastUpdated && { dateModified: String(detailedStats.lastUpdated).slice(0, 10) }),
    author: {
      '@type': 'RealEstateAgent',
      name: 'Ryan Adamson',
      worksFor: { '@type': 'Organization', name: 'Coldwell Banker Realty — St. Armands' },
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://adamsonfl.com/' },
      { '@type': 'ListItem', position: 2, name: 'Areas', item: 'https://adamsonfl.com/areas' },
      { '@type': 'ListItem', position: 3, name: area.name, item: `https://adamsonfl.com/areas/${area.slug}` },
    ],
  },
];

if (media.video) {
  jsonLd.push({
    '@type': 'VideoObject',
    name: media.video.title,
    description: media.video.description,
    thumbnailUrl: [`https://adamsonfl.com${media.video.poster}`],
    uploadDate: media.video.uploadDate,
    duration: media.video.duration,
    contentUrl: `https://adamsonfl.com${media.video.src}`,
    publisher: { '@type': 'RealEstateAgent', name: 'The Adamson Group' },
  });
}
---

<BaseLayout title={`${area.name} Real Estate`} description={description} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${area.heroImage || `/images/areas/${area.slug}.jpg`}'); background-color: var(--color-black);`}
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/90" />

    <div class="relative z-10 container">
      <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">
        Area Guide
      </p>
      <h1 class="font-display text-white mb-4">{area.name}</h1>
      <p class="text-lg text-white/70 max-w-2xl leading-relaxed">
        {area.tagline}
      </p>
    </div>
  </section>

  <!-- Weekly market-minute video (slug-keyed via area-media.json) -->
  {media.video && (
    <section class="section dark-section">
      <div class="container-narrow text-center">
        <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">{media.video.eyebrow}</p>
        <h2 class="accent-underline-center mb-6">{media.video.title}</h2>
        <div class="mx-auto rounded-xl overflow-hidden border border-white/10" style="max-width:760px;">
          <video
            src={media.video.src}
            poster={media.video.poster}
            controls
            muted
            autoplay
            loop
            playsinline
            preload="metadata"
            class="block w-full h-auto"
            style="aspect-ratio:16/9; background:#0a1f3c;"
          ></video>
        </div>
        {media.video.caption && (
          <p class="text-white/60 text-sm mt-4 max-w-xl mx-auto">{media.video.caption}</p>
        )}
      </div>
    </section>
  )}

  <!-- Overview + nested area imagery (gallery slug-keyed via area-media.json) -->
  <section class="section light-section">
    <div class={media.gallery && media.gallery.length > 0 ? "container" : "container-narrow"}>
      <div class={media.gallery && media.gallery.length > 0 ? "grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-12 items-start" : ""}>
        <div>
          <h2 class="accent-underline mb-6">About {area.name}</h2>
          <p class="text-[var(--color-text-muted)] leading-relaxed text-lg mb-8">
            {media.summary || area.description}
          </p>

          {area.highlights && area.highlights.length > 0 && (
            <div class="flex flex-wrap gap-3">
              {area.highlights.map((highlight: string) => (
                <span class="inline-block bg-[var(--color-cbgl-blue)]/10 text-[var(--color-cbgl-blue)] font-accent text-xs uppercase tracking-wider px-4 py-2 rounded-full border border-[var(--color-cbgl-blue)]/20">
                  {highlight}
                </span>
              ))}
            </div>
          )}
        </div>

        {media.gallery && media.gallery.length > 0 && (
          <div class="grid grid-cols-2 gap-3 lg:gap-4">
            {media.gallery.map((g: any) => (
              <figure class="group relative overflow-hidden rounded-lg aspect-[4/3] m-0">
                <img src={g.src} alt={g.alt} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent" />
                <figcaption class="absolute bottom-0 left-0 right-0 p-3 font-accent text-[0.7rem] uppercase tracking-[0.12em] text-white/90">{g.caption}</figcaption>
              </figure>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Live IDX listings + off-market CTA (rendered only for areas with a widget id) -->
  {idxWidgetId && (
    <IdxAreaShowcase
      widgetId={idxWidgetId}
      areaName={area.name}
      label="Live Listings"
    />
  )}

  <!-- Photo gallery is now nested in the Overview section above -->

  <!-- Market Stats — legacy placeholder block. Suppressed automatically
       whenever a detailedStats JSON file exists for this area, so the
       live MLS pipeline table becomes the single source of truth. -->
  {area.marketStats && !detailedStats && (
    <MarketStats areaName={area.name} stats={area.marketStats} />
  )}

  <!-- Detailed Sold + Pending Market Table (live MLS pipeline) -->
  {detailedStats && (
    <DetailedMarketTable areaName={area.name} stats={detailedStats} />
  )}

  <!-- Enriched AEO market summary — active inventory, price bands, sold comps -->
  {detailedStats && (detailedStats.active || detailedStats.sold) && (
    <AreaMarketSummary areaName={area.name} areaSlug={area.slug} stats={detailedStats} />
  )}

  <!-- Condo tier table — active inventory grouped by construction era.
       Nested lower on the page, just above Typical Condo Dues. -->
  {detailedStats && detailedStats.condoTiers && detailedStats.condoTiers.length > 0 && (
    <CondoTiersTable
      areaName={area.name}
      areaSlug={area.slug}
      tiers={detailedStats.condoTiers}
      scope={detailedStats.condoTiersScope}
      lastUpdated={detailedStats.lastUpdated}
    />
  )}

  <!-- Typical Condo Dues — Min / Median / Max monthly condo fee on a range bar -->
  {condoDues && (
    <section class="section dark-section">
      <div class="container-narrow">
        <h2 class="accent-underline mb-3">Typical Condo Dues</h2>
        <p class="text-[var(--color-text-on-dark-muted)] leading-relaxed mb-10 max-w-2xl">
          Monthly condo fees for active and recently sold {area.name} condominiums, villas and
          townhouses — from the lowest-fee associations to full-service luxury buildings.
        </p>

        <div class="bg-[var(--color-black-card)] rounded-2xl border border-[var(--color-border-dark)] px-6 sm:px-10 py-10">
          <div class="text-center mb-12">
            <p class="font-accent text-xs uppercase tracking-[0.18em] text-[var(--color-cbgl-blue-light)] mb-1">Median Monthly Dues</p>
            <p class="font-display text-4xl sm:text-5xl font-bold text-white">{fmtUsd(condoDues.median)}<span class="text-base text-white/40 font-normal ml-2">/ mo</span></p>
          </div>
          <div class="relative pt-7 pb-1">
            <div class="absolute top-0 -translate-x-1/2 whitespace-nowrap" style={`left: ${duesPct}%;`}>
              <span class="font-accent text-[0.7rem] uppercase tracking-wider text-white/70">Median</span>
            </div>
            <div class="relative h-2.5 rounded-full bg-[var(--color-dark-elevated)]">
              <div class="absolute inset-0 rounded-full" style="background: linear-gradient(90deg, var(--color-cbgl-blue) 0%, var(--color-cbgl-blue-light) 55%, var(--color-cbgl-gold, #C5A55A) 100%); opacity:0.9;"></div>
              <div class="absolute top-1/2 -translate-x-1/2 -translate-y-1/2 w-5 h-5 rounded-full bg-white shadow-lg ring-4 ring-[var(--color-cbgl-blue)]" style={`left: ${duesPct}%;`}></div>
            </div>
            <div class="flex justify-between mt-5">
              <div class="text-left">
                <p class="font-accent text-[0.65rem] uppercase tracking-wider text-white/40 mb-0.5">Minimum</p>
                <p class="font-display text-lg font-semibold text-white">{fmtUsd(condoDues.min)}<span class="text-xs text-white/40 font-normal ml-1">/ mo</span></p>
              </div>
              <div class="text-right">
                <p class="font-accent text-[0.65rem] uppercase tracking-wider text-white/40 mb-0.5">Maximum</p>
                <p class="font-display text-lg font-semibold text-white">{fmtUsd(condoDues.max)}<span class="text-xs text-white/40 font-normal ml-1">/ mo</span></p>
              </div>
            </div>
          </div>
        </div>
        <p class="text-xs text-[var(--color-text-on-dark-subtle)] mt-6 leading-relaxed">
          Source: Stellar MLS via the Adamson Group data pipeline. Monthly condo dues only; entries
          under $100/mo are treated as data-entry errors and omitted. Figures approximate and vary
          by building, square footage and amenities.
        </p>
      </div>
    </section>
  )}

  {/* Waterfront & Market Breakdown — removed for now (repetitive). Re-enable by uncommenting.
  {detailedStats && detailedStats.waterfrontSegments && detailedStats.waterfrontSegments.length > 0 && (
    <WaterfrontSegments areaName={area.name} stats={detailedStats} />
  )}
  */}

  <!-- FAQ Section -->
  {allFaqs.length > 0 && (
    <FAQSchema
      faqs={allFaqs}
      heading={`${area.name} Market Questions & FAQ`}
    />
  )}

  <!-- CTA -->
  <section class="cbgl-section py-16">
    <div class="container text-center">
      <h2 class="font-display text-2xl text-white mb-4">
        Interested in {area.name}?
      </h2>
      <p class="text-white/70 mb-8 max-w-lg mx-auto">
        Get personalized market insights and property recommendations from a local expert.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Talk to Ryan
      </Button>
    </div>
  </section>

</BaseLayout>

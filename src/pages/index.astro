---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AreaCard from '@/components/market/AreaCard.astro';
import Testimonials from '@/components/Testimonials.astro';
import Button from '@/components/ui/Button.astro';
import { getAreas, getSiteSettings } from '@/lib/sanity';
import areasFallback from '@/data/areas.json';
import areaMedia from '@/data/area-media.json';

const description = 'Ryan Adamson is a luxury real estate specialist at Coldwell Banker St. Armands, serving Sarasota, Longboat Key, St. Armands and Lido, Siesta Key, and the barrier islands. Expert market insights and waterfront properties.';

// Fallback JSON drives WHICH areas exist; Sanity is an editable content
// overlay matched by slug. Mirrors src/pages/areas/index.astro so the two
// pages can never disagree on which area tiles render.
const sanityAreasRaw = (await getAreas()) || [];
const sanityBySlug = new Map<string, any>(
  sanityAreasRaw.filter((a: any) => a?.slug).map((a: any) => [a.slug, a])
);

// Live pipeline stats (daily-refreshed *-stats.json) drive card prices so the
// homepage can never disagree with the area pages' market tables.
const statsModules = import.meta.glob('../data/*-stats.json', { eager: true }) as Record<string, any>;
const statsBySlug: Record<string, any> = {};
for (const [path, mod] of Object.entries(statsModules)) {
  const m = path.match(/\/([\w-]+)-stats\.json$/);
  if (m) statsBySlug[m[1]] = (mod as any).default ?? mod;
}

const areas = areasFallback.areas.map((fallback) => {
  const sanity = sanityBySlug.get(fallback.slug);
  return {
    name: sanity?.name || fallback.name,
    slug: fallback.slug,
    tagline: sanity?.tagline || fallback.tagline,
    medianPrice: statsBySlug[fallback.slug]?.active?.medianPrice || sanity?.marketStats?.medianPrice || fallback.marketStats?.medianPrice || '',
    imageSrc: sanity?.cardImage || (areaMedia as Record<string, any>)[fallback.slug]?.cardImage || undefined,
  };
});

// JSON-LD structured data for homepage
const jsonLd = [
  {
    '@type': 'RealEstateAgent',
    name: 'Ryan Adamson',
    description: 'Luxury real estate specialist serving Sarasota and the barrier islands.',
    url: 'https://adamsonfl.com',
    telephone: '+19417139234',
    sameAs: [
      'https://share.google/AOMDgknj0Rf0gtAvX',
      'https://www.facebook.com/ryan.adamson.941',
      'https://ryanadamson.sites.cbmoxi.com',
      'https://www.zillow.com/profile/The%20Adamson%20Group',
      'https://www.coldwellbankerhomes.com/fl/sarasota/agent/ryan-adamson/aid_295651/',
      'https://www.coldwellbanker.com/fl/sarasota/agents/ryan-adamson/aid-P00200000000031HxjHn46hpEmg2ylx6HJpL5DOc',
      'https://www.coldwellbankerluxury.com/specialist/Nr0ouvr/ryan-adamson',
      'https://www.homes.com/real-estate-agents/ryan-adamson/c6wpbhg/',
      'https://adamson-group.com/',
    ],
    identifier: {
      '@type': 'PropertyValue',
      name: 'Florida Real Estate License',
      value: 'SL3457783',
    },
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      name: 'Certified Waterfront Specialist (CWS)',
      credentialCategory: 'certification',
      recognizedBy: {
        '@type': 'Organization',
        name: 'REALTOR® Association of Sarasota and Manatee (RASM)',
      },
    },
    email: 'Ryan@Adamson-Group.com',
    image: 'https://adamsonfl.com/images/ryan-adamson.jpg',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '423 St Armands Cir',
      addressLocality: 'Sarasota',
      addressRegion: 'FL',
      postalCode: '34236',
      addressCountry: 'US',
    },
    areaServed: [
      { '@type': 'City', name: 'Sarasota', sameAs: 'https://en.wikipedia.org/wiki/Sarasota,_Florida' },
      { '@type': 'Place', name: 'Longboat Key' },
      { '@type': 'Place', name: 'St. Armands and Lido' },
      { '@type': 'Place', name: 'Siesta Key' },
      { '@type': 'Place', name: 'Bird Key' },
    ],
    worksFor: {
      '@type': 'RealEstateAgent',
      name: 'Coldwell Banker Realty — St. Armands',
    },
  },
  {
    '@type': 'WebSite',
    name: 'Ryan Adamson Luxury Real Estate',
    url: 'https://adamsonfl.com',
    description: description,
  },
];
---

<BaseLayout title="Home" description={description} jsonLd={jsonLd}>

  <!-- ====== VIDEO HERO SECTION ====== -->
  <section class="video-hero flex items-center justify-center">
    <!-- Video Background -->
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/images/hero-poster.jpg"
    >
      <source src="/videos/hero-banner.mp4" type="video/mp4" />
    </video>

    <!-- Dark Overlay -->
    <div class="overlay"></div>

    <!-- Hero Content -->
    <div class="content text-center px-6 max-w-3xl mx-auto">
      <!-- Logos — hidden on mobile (top nav already shows both brands) -->
      <div class="hidden sm:flex items-center justify-center gap-6 mb-8">
        <img
          src="/images/logos/adamson-group-black.png"
          alt="Adamson Group"
          class="h-16 w-auto"
          style="filter: invert(1) brightness(100);"
        />
        <span class="w-px h-10 bg-white/30"></span>
        <img src="/images/logos/cb-full-horz-white.png" alt="Coldwell Banker Realty" class="h-12 w-auto" />
      </div>

      <h1 class="font-display text-white mb-4 text-3xl sm:text-5xl md:text-6xl" style="line-height: 1.15;">
        Luxury Real Estate on Sarasota's Barrier Islands
      </h1>

      <!-- Tagline bar — matches existing site's "INTEGRITY | PASSION | PROFESSIONALISM" -->
      <p class="font-accent text-xs sm:text-sm uppercase tracking-[0.25em] sm:tracking-[0.3em] text-white/80 mb-6 sm:mb-10">
        Integrity &nbsp;|&nbsp; Passion &nbsp;|&nbsp; Professionalism
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/areas" variant="cbgl" size="lg">
          Explore Areas
        </Button>
        <Button href="/contact" variant="outline" size="lg">
          Get in Touch
        </Button>
        <Button href="/find-my-dream-home" variant="primary" size="lg">
          Off-Market Properties
        </Button>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
      <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- ====== FEATURED PROPERTIES PLACEHOLDER ====== -->
  <!-- Phase 2: IDX listing cards will go here -->

  <!-- ====== AREAS SECTION (Dark) ====== -->
  <section class="section dark-section">
    <div class="container">
      <div class="text-center mb-14">
        <p class="section-label text-[var(--color-cbgl-blue-light)] mb-3">
          Areas We Serve
        </p>
        <h2 class="accent-underline-center">
          Sarasota's Most Coveted Communities
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((area) => (
          <AreaCard
            name={area.name}
            slug={area.slug}
            tagline={area.tagline}
            medianPrice={area.medianPrice}
            imageSrc={area.imageSrc}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ====== VALUE PROPOSITION (Light break) ====== -->
  <section class="section light-section">
    <div class="container-narrow text-center">
      <p class="section-label text-[var(--color-cbgl-blue)] mb-3">
        Why Ryan Adamson
      </p>
      <h2 class="accent-underline-center mb-10">
        Local Expertise, Luxury Service
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-left">
        <div>
          <h3 class="text-lg mb-3" style="font-family: var(--font-body); font-weight: 600;">
            Market Intelligence
          </h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
            Real-time data from the Sarasota MLS, analyzed and presented to help you make confident decisions in the luxury market.
          </p>
        </div>
        <div>
          <h3 class="text-lg mb-3" style="font-family: var(--font-body); font-weight: 600;">
            Island Specialist
          </h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
            Deep knowledge of every barrier island community — from Longboat Key estates to Siesta Key beachfront. As a Certified Waterfront Specialist (CWS), Ryan navigates the dock, seawall, bridge-clearance, and riparian-rights details that out-of-area buyers rarely anticipate.
          </p>
        </div>
        <div>
          <h3 class="text-lg mb-3" style="font-family: var(--font-body); font-weight: 600;">
            Coldwell Banker Network
          </h3>
          <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
            Backed by the global reach and trusted reputation of Coldwell Banker, connecting luxury buyers and sellers across markets.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== SPECIALTIES SECTION (Dark, matching AdamsonFL.com layout) ====== -->
  <section class="section dark-section-elevated">
    <div class="container">
      <div class="text-center mb-12">
        <p class="section-label text-[var(--color-gold)] mb-3">
          Offering the Premiere Relocation Services
        </p>
        <h2>Ryan Specialties</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { label: 'Buyers Agent', image: '/images/specialties/buyers-agent.jpg' },
          { label: 'Listing Agent', image: '/images/specialties/listing-agent.jpg' },
          { label: 'Relocation', image: '/images/specialties/relocation.jpg' },
          { label: 'Consulting', image: '/images/specialties/consulting.jpg' },
        ].map((specialty) => (
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden group cursor-pointer">
            <div
              class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
              style={`background-image: url('${specialty.image}'); background-color: var(--color-dark-elevated);`}
            />
            <div class="absolute inset-0 bg-black/50 group-hover:bg-black/30 transition-colors duration-300" />
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="font-accent text-sm uppercase tracking-[0.2em] font-semibold text-white">
                {specialty.label}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== TESTIMONIALS (Dark) ====== -->
  <Testimonials />

  <!-- ====== OFF-MARKET TEASER (Private Seller Registry) ====== -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg,#000000 0%,#0c1828 55%,#000000 100%);">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 74% 50%, rgba(197,165,90,0.08) 0%, transparent 60%);"></div>
    <div class="relative z-10 container py-20 sm:py-24 text-center">
      <p class="section-label text-[var(--color-gold)] mb-5 tracking-[0.3em]">
        The Quiet Market
      </p>
      <h2 class="font-display text-white text-3xl sm:text-4xl lg:text-5xl leading-[1.15] max-w-3xl mx-auto mb-6">
        Not everything worth owning is for sale.
        <em class="not-italic text-[var(--color-gold)]">Until it is.</em>
      </h2>
      <p class="text-white/55 text-base max-w-xl mx-auto leading-relaxed mb-10">
        Some of Sarasota's most significant sales never touch the MLS. If the right offer
        found you tomorrow, would you be ready? Register your home confidentially with
        Ryan &mdash; no listing, no obligation, no algorithm.
      </p>
      <a
        href="/off-market"
        class="inline-flex items-center gap-2 font-accent text-[11px] uppercase tracking-[0.25em] text-[var(--color-gold)] border border-[var(--color-gold)]/40 px-8 py-3.5 rounded hover:bg-[var(--color-gold)]/10 hover:border-[var(--color-gold)]/70 transition-all duration-200"
      >
        Enter the Private Registry
        <span class="text-sm leading-none">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- ====== CTA SECTION (CBGL Blue) — with Ryan portrait on desktop ====== -->
  <section class="cbgl-section py-20 overflow-hidden">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-center">
        <div class="hidden md:block md:col-span-2">
          <img
            src="/images/ryan-adamson-transparent.webp"
            alt="Ryan Adamson, Coldwell Banker Realty"
            class="w-full max-w-xs mx-auto"
            style="-webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 95%); mask-image: linear-gradient(to bottom, black 55%, transparent 95%);"
            loading="lazy"
          />
        </div>
        <div class="md:col-span-3 text-center md:text-left">
          <h2 class="font-display text-3xl text-white mb-4">
            Ready to Find Your Place in Paradise?
          </h2>
          <p class="text-white/70 mb-8 max-w-lg mx-auto md:mx-0">
            Whether you're buying, selling, or exploring the Sarasota luxury market, let's start the conversation.
          </p>
          <Button href="/contact" variant="primary" size="lg">
            Schedule a Consultation
          </Button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

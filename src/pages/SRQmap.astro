---
// build-touch 2026-07-06: MapMe dining photos, UTC pins, UX polish (sticky back, map-click close), AdamsonFL.com cross-links
import allPins from '../data/srqmap-pins.json';
import rawEvents from '../data/srqmap-events.json';

// Categories currently shown on the map (others temporarily hidden — restore by adding ids back)
const VISIBLE_GROUPS = ['events', 'beaches', 'things', 'dining', 'golf'];

// "Events This Week" — machine-maintained by the daily `srqmap-events` scheduled task.
// Source file: src/data/srqmap-events.json (do NOT hand-edit; see scripts/events/).
// Past events are also dropped here at build time as a safety net (task prunes them too).
const todayET = new Date(Date.now() - 5 * 3600 * 1000).toISOString().slice(0, 10);
const eventPins = (rawEvents as any[])
  .filter((e) => ((e.end_date || e.start_date) >= todayET))
  .map((e) => ({
    group: 'events',
    name: e.name,
    lat: e.lat,
    lng: e.lng,
    address: e.address || '',
    blurb: e.blurb || '',
    website: e.website || '',
    photos: Array.isArray(e.photos) ? e.photos : [],
    photo_credit: e.photo_credit || '',
    price: e.dates_label || '',
    vibe: e.hours_label || '',
    good_for: e.venue || '',
    start_date: e.start_date,
    end_date: e.end_date || e.start_date,
  }));
const pins = [...eventPins, ...allPins.filter((p) => VISIBLE_GROUPS.includes(p.group))];

const ICONS = {
  events: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M12 13l1.3 2.6 2.7.4-2 1.9.5 2.7-2.5-1.3-2.5 1.3.5-2.7-2-1.9 2.7-.4Z"/>',
  beaches: '<path d="M17.5 19H22a4.5 4.5 0 0 0-9 0h4.5Z"/><path d="M12 19v3"/><path d="M2 22h20"/><path d="M5.2 11.2 2 8a10 10 0 0 1 14-1.4"/><path d="M16 6.6c2.6 2 3.6 5.4 2.4 8.4l-4.4-3.4Z"/><path d="M5.2 11.2 14 18"/>',
  golf: '<path d="M12 18v-13"/><path d="M12 5l7 3-7 3"/><circle cx="12" cy="20.5" r="1.5"/><path d="M7 21.2c-1.9-.4-3-1-3-1.7 0-1.1 3.6-2 8-2s8 .9 8 2c0 .7-1.1 1.3-3 1.7"/>',
  things: '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  dining: '<path d="M3 2v7c0 1.1.9 2 2 2h0c1.1 0 2-.9 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Z"/>',
  condos: '<rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M16 6h.01M8 10h.01M16 10h.01M8 14h.01M16 14h.01"/>',
  newdev: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18"/><path d="M6 12H4a2 2 0 0 0-2 2v8h18"/><path d="M18 9h2a2 2 0 0 1 2 2v11"/><path d="M10 6h4M10 10h4M10 14h4"/>',
  areas:  '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
};
const GROUPS = [
  { id: 'events', label: 'Events This Week',   color: '#D1495B', svg: ICONS.events },
  { id: 'beaches', label: 'Beaches & Access',   color: '#1A9BB8', svg: ICONS.beaches },
  { id: 'things', label: 'Things to Do',        color: '#4C956C', svg: ICONS.things },
  { id: 'dining', label: 'Dining & Drinks',     color: '#C0613B', svg: ICONS.dining },
  { id: 'golf',   label: 'Golf Courses',        color: '#0B6E4F', svg: ICONS.golf },
  { id: 'condos', label: 'Condos & Residences', color: '#2E86AB', svg: ICONS.condos },
  { id: 'newdev', label: 'New Developments',    color: '#7D5BA6', svg: ICONS.newdev },
  { id: 'areas',  label: 'Communities & Areas', color: '#C2913B', svg: ICONS.areas  },
].filter((g) => VISIBLE_GROUPS.includes(g.id));
const groupMap = Object.fromEntries(GROUPS.map((g) => [g.id, g]));

const phone = '(941) 713-9234';
const tel = '19417139234';

const pageTitle = 'Sarasota Area Guide — Beaches, Golf, Restaurants & Neighborhoods Map | AdamsonFL';
const pageDesc = 'An interactive local map of Sarasota and the Keys from Ryan Adamson, PA: beach access points on Siesta, Lido and Longboat Key, public and private golf courses within 15 miles of St. Armands, top restaurants and bars, things to do, and this week’s local events.';
const canonical = 'https://adamsonfl.com/srqmap';

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Sarasota & the Keys — Local Area Guide',
  description: pageDesc,
  numberOfItems: pins.length,
  itemListElement: pins.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: p.group === 'events'
      ? {
          '@type': 'Event',
          name: p.name,
          ...(p.blurb ? { description: p.blurb } : {}),
          ...(p.website ? { url: p.website } : {}),
          startDate: p.start_date,
          endDate: p.end_date,
          location: {
            '@type': 'Place',
            ...(p.good_for ? { name: p.good_for } : {}),
            ...(p.address ? { address: p.address } : {}),
            geo: { '@type': 'GeoCoordinates', latitude: p.lat, longitude: p.lng },
          },
        }
      : {
          '@type': p.group === 'golf' ? 'GolfCourse' : p.group === 'beaches' ? 'Beach' : 'Place',
          name: p.name,
          ...(p.address ? { address: p.address } : {}),
          ...(p.blurb ? { description: p.blurb } : {}),
          ...(p.website ? { url: p.website } : {}),
          geo: { '@type': 'GeoCoordinates', latitude: p.lat, longitude: p.lng },
        },
  })),
};
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<link rel="canonical" href={canonical} />
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:url" content={canonical} />
<meta name="robots" content="index,follow" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Montserrat:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<script type="application/ld+json" set:html={JSON.stringify(itemList)} />
<style is:global>
  :root{
    --navy:#0B3A5B; --ink:#0A2A40; --blue:#2E86AB; --blue-deep:#1C6489;
    --gold:#C5A55A; --sand:#EDE3D1; --cream:#FBF8F2; --paper:#FFFFFF;
    --line:rgba(11,58,91,.14); --muted:#5C6B76;
    --rail-w:386px; --bar-h:62px; --shadow:0 18px 50px -20px rgba(10,42,64,.45);
  }
  *{box-sizing:border-box}
  html,body{height:100%;margin:0}
  body{font-family:"Inter",system-ui,sans-serif;color:var(--ink);background:var(--cream);overflow:hidden}
  .visually-hidden{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}

  .bar{position:fixed;top:0;left:0;right:0;height:var(--bar-h);z-index:1100;display:flex;align-items:center;gap:14px;padding:0 20px;background:var(--cream);border-bottom:1px solid var(--line)}
  .bar::after{content:"";position:absolute;left:0;right:0;bottom:-9px;height:9px;background:radial-gradient(circle at 10px -4px, transparent 9px, var(--cream) 10px) repeat-x;background-size:20px 18px;pointer-events:none}
  .brand{display:flex;align-items:center;gap:12px;margin-right:auto;min-width:0;text-decoration:none;color:inherit}
  .brand:hover .gname{color:var(--blue-deep)}
  .home-link{display:inline-flex;align-items:center;gap:7px;flex:none;text-decoration:none;color:var(--navy);border:1.5px solid var(--line);font-family:"Montserrat",sans-serif;font-weight:600;font-size:12px;letter-spacing:.04em;padding:9px 14px;border-radius:999px;transition:border-color .15s ease,color .15s ease,background .15s ease}
  .home-link:hover{border-color:var(--gold);color:var(--blue-deep);background:var(--cream)}
  .home-link svg{width:14px;height:14px}
  .brand .logo{height:44px;width:auto;flex:none;display:block}
  .brand .lockup{display:flex;flex-direction:column;line-height:1.06;min-width:0;border-left:1px solid var(--line);padding-left:12px}
  .brand .gname{font-family:"Playfair Display",Georgia,serif;font-weight:600;font-size:18.5px;letter-spacing:.2px;color:var(--navy);white-space:nowrap}
  .brand .tag{font-family:"Montserrat",sans-serif;font-size:9.5px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-top:4px;white-space:nowrap}
  .call{display:inline-flex;align-items:center;gap:8px;flex:none;text-decoration:none;color:var(--paper);background:var(--navy);font-family:"Montserrat",sans-serif;font-weight:600;font-size:13px;letter-spacing:.03em;padding:10px 15px;border-radius:999px;box-shadow:0 6px 16px -8px rgba(11,58,91,.7);transition:transform .15s ease, background .15s ease}
  .call:hover{background:var(--blue-deep);transform:translateY(-1px)}
  .call svg{width:15px;height:15px}
  .call .num{font-variant-numeric:tabular-nums}

  #map{position:fixed;inset:var(--bar-h) 0 0 0;background:#AEC9D6;z-index:1}
  .leaflet-div-icon{background:transparent;border:none}
  .leaflet-control-attribution{font-size:10px;opacity:.85}

  .rail{position:fixed;z-index:1000;top:calc(var(--bar-h) + 18px);left:18px;width:var(--rail-w);max-height:calc(100vh - var(--bar-h) - 36px);display:flex;flex-direction:column;background:var(--paper);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow);overflow:hidden}
  .rail-head{padding:18px 18px 14px;border-bottom:1px solid var(--line)}
  .rail-eyebrow{font-family:"Montserrat",sans-serif;font-size:10.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin:0 0 6px}
  .rail-title{font-family:"Playfair Display",Georgia,serif;font-weight:600;font-size:25px;margin:0;color:var(--navy);line-height:1.08}
  .rail-sub{margin:8px 0 0;font-size:12.5px;color:var(--muted)}
  .rail-sub b{color:var(--ink);font-weight:600}
  .subnote-link{color:var(--blue-deep);font-weight:600;text-decoration:none}
  .subnote-link:hover{text-decoration:underline}

  .chips{display:flex;flex-wrap:wrap;gap:7px;padding:14px 18px;border-bottom:1px solid var(--line)}
  .chip{--c:var(--blue);font-family:"Montserrat",sans-serif;text-transform:uppercase;letter-spacing:.05em;display:inline-flex;align-items:center;gap:6px;cursor:pointer;font-size:11px;font-weight:600;color:var(--ink);padding:6px 11px 6px 9px;border:1px solid var(--line);border-radius:999px;background:var(--cream);user-select:none;transition:all .14s ease}
  .chip .dot{width:9px;height:9px;border-radius:50%;background:var(--c);flex:none}
  .chip[aria-pressed="true"]{background:var(--c);border-color:var(--c);color:#fff}
  .chip[aria-pressed="true"] .dot{background:rgba(255,255,255,.9)}
  .chip:focus-visible{outline:2px solid var(--navy);outline-offset:2px}

  .search{position:relative;padding:12px 18px 6px}
  .search svg{position:absolute;left:31px;top:22px;width:15px;height:15px;stroke:var(--muted);fill:none;stroke-width:2;pointer-events:none}
  .search input{width:100%;font-family:inherit;font-size:13.5px;color:var(--ink);padding:10px 12px 10px 34px;border:1px solid var(--line);border-radius:10px;background:var(--cream);outline:none;-webkit-appearance:none;transition:border-color .14s ease,box-shadow .14s ease}
  .search input::placeholder{color:var(--muted)}
  .search input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(197,165,90,.20)}
  .empty{padding:26px 18px;text-align:center;color:var(--muted);font-size:13px;line-height:1.5}
  .list{overflow-y:auto;padding:6px 0;-webkit-overflow-scrolling:touch;overscroll-behavior:contain}
  .card{display:grid;grid-template-columns:34px 1fr;gap:11px;align-items:start;padding:13px 18px;cursor:pointer;border-bottom:1px solid rgba(11,58,91,.06);transition:background .12s ease}
  .card:hover{background:var(--cream)}
  .card.active{background:#F2F6F8;box-shadow:inset 3px 0 0 var(--blue)}
  .card .marker{width:30px;height:30px;border-radius:50% 50% 50% 2px;transform:rotate(45deg);background:var(--c);display:grid;place-items:center;margin-top:2px;flex:none;box-shadow:0 3px 7px -2px rgba(10,42,64,.45)}
  .card .marker svg{transform:rotate(-45deg);width:15px;height:15px;stroke:#fff;fill:none;stroke-width:2}
  .card h3{margin:0;font-size:14.5px;font-weight:600;color:var(--ink)}
  .card .meta{margin:3px 0 0;font-size:11.5px;color:var(--muted);display:flex;align-items:center;gap:7px;flex-wrap:wrap}
  .card .cat-label{font-family:"Montserrat",sans-serif;text-transform:uppercase;letter-spacing:.08em;font-weight:600;font-size:10px}

  .detail{display:none;flex-direction:column;overflow-y:auto;overscroll-behavior:contain}
  .detail.show{display:flex}
  .back{position:sticky;top:0;z-index:3;display:flex;width:100%;align-items:center;gap:8px;background:var(--paper);border:none;border-bottom:1px solid var(--line);cursor:pointer;font-family:"Montserrat",sans-serif;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--blue-deep);padding:14px 18px;text-align:left;transition:background .12s ease}
  .back:hover{background:var(--cream);color:var(--navy)}
  .detail-body{padding:6px 20px 22px}
  .detail .kicker{font-family:"Montserrat",sans-serif;display:flex;align-items:center;gap:8px;font-size:10.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--c);margin-bottom:8px}
  .detail .kicker .pin{width:11px;height:11px;border-radius:50%;background:var(--c)}
  .detail h2{font-family:"Playfair Display",Georgia,serif;font-weight:600;font-size:27px;line-height:1.1;margin:0 0 4px;color:var(--navy)}
  .detail .addr{font-size:12px;color:var(--muted);margin:0 0 14px}
  .detail .facts{display:flex;flex-wrap:wrap;gap:6px;margin:0 0 14px}
  .detail .fact{font-size:11px;font-weight:600;color:#37535f;background:var(--cream);border:1px solid var(--line);border-radius:999px;padding:4px 10px}
  .detail p.blurb{font-size:14px;line-height:1.62;color:#2B3942;margin:0 0 16px;white-space:pre-line}
  .tip{background:var(--cream);border:1px solid var(--line);border-left:3px solid var(--gold);border-radius:0 10px 10px 0;padding:12px 14px;margin:0 0 18px}
  .tip .tip-h{font-family:"Montserrat",sans-serif;font-size:10.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin:0 0 5px}
  .tip p{margin:0;font-size:13px;line-height:1.55;color:#374550;font-style:italic}
  .detail .links{display:flex;flex-direction:column;gap:9px}
  .detail-cta{display:flex;align-items:center;justify-content:center;gap:9px;text-decoration:none;background:var(--navy);color:#fff;font-family:"Montserrat",sans-serif;font-weight:600;font-size:12.5px;letter-spacing:.04em;text-transform:uppercase;padding:13px;border-radius:11px;transition:background .15s ease}
  .detail-cta:hover{background:var(--blue-deep)}
  .detail-link{display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;color:var(--blue-deep);font-weight:600;font-size:13px;padding:11px;border:1px solid var(--line);border-radius:11px}
  .detail-link:hover{background:var(--cream)}
  .detail .signoff{text-align:center;font-size:11.5px;color:var(--muted);margin:13px 0 0}

  .handle{display:none}
  .pin-marker{cursor:pointer;width:30px;height:30px;position:relative;transition:transform .15s ease}
  .pin-marker .body{width:30px;height:30px;border-radius:50% 50% 50% 2px;transform:rotate(45deg);background:var(--c);display:grid;place-items:center;box-shadow:0 5px 12px -4px rgba(10,42,64,.6);border:2px solid rgba(255,255,255,.9)}
  .pin-marker .body svg{transform:rotate(-45deg);width:15px;height:15px;stroke:#fff;fill:none;stroke-width:2}
  .pin-marker:hover{transform:translateY(-3px) scale(1.05)}
  .pin-marker.active{transform:translateY(-4px) scale(1.14);z-index:5}
  /* Locate-me control */
  .leaflet-control.locate-ctl{margin-bottom:10px;border:none;background:transparent;box-shadow:none}
  .locate-btn{width:36px;height:36px;display:grid;place-items:center;background:#fff;border:1px solid rgba(11,58,91,.12);border-radius:8px;cursor:pointer;color:var(--navy);padding:0;box-shadow:0 1px 5px rgba(10,42,64,.35)}
  .locate-btn:hover{background:var(--cream)}
  .locate-btn:focus-visible{outline:2px solid var(--navy);outline-offset:2px}
  .locate-btn svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
  .locate-btn.locating{color:var(--blue)}
  .locate-btn.locating svg{animation:locspin 1s linear infinite}
  .locate-btn.active{color:#fff;background:var(--blue);border-color:var(--blue)}
  @keyframes locspin{to{transform:rotate(360deg)}}
  .you-dot{position:relative;width:18px;height:18px}
  .you-dot .core{position:absolute;left:4px;top:4px;width:10px;height:10px;border-radius:50%;background:var(--blue);border:2px solid #fff;box-shadow:0 0 0 1px rgba(10,42,64,.35)}
  .you-dot .ring{position:absolute;left:-3px;top:-3px;width:24px;height:24px;border-radius:50%;background:rgba(46,134,171,.35);animation:youpulse 2s ease-out infinite}
  @keyframes youpulse{0%{transform:scale(.4);opacity:.85}100%{transform:scale(1.7);opacity:0}}

  @media (max-width:720px){
    :root{--bar-h:56px}
    .leaflet-control.locate-ctl{position:fixed;top:calc(var(--bar-h) + 12px);right:12px;bottom:auto;left:auto;margin:0;z-index:1000}
    .brand .lockup{display:none}
    .home-link span{display:none}
    .home-link{padding:9px 11px}
    .call{padding:9px 13px;font-size:13px}
    .rail{left:0;right:0;width:auto;top:auto;bottom:0;border-radius:18px 18px 0 0;max-height:74vh;transition:transform .32s cubic-bezier(.33,1,.68,1);will-change:transform;box-shadow:0 -10px 34px rgba(10,42,64,.22)}
    .rail.collapsed{transform:translateY(calc(100% - 152px))}
    .handle{display:flex;justify-content:center;padding:8px 0 2px;cursor:pointer}
    .handle .bar-grip{width:40px;height:4px;border-radius:999px;background:var(--line)}
    .rail-head{padding-top:4px}
    .list{max-height:44vh}
    .detail{max-height:64vh}
  }
  @media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
  /* ===== Soft lead gate (SRQmap only) ===== */
  .gate{display:none;position:fixed;inset:0;z-index:2000;background:rgba(10,42,64,.55);-webkit-backdrop-filter:blur(3px);backdrop-filter:blur(3px);align-items:center;justify-content:center;padding:20px}
  .gate.show{display:flex}
  .gate-card{position:relative;width:100%;max-width:430px;max-height:90vh;overflow-y:auto;background:var(--paper);border-radius:18px;box-shadow:0 30px 80px -20px rgba(10,42,64,.6);padding:30px 26px 22px;text-align:center}
  .gate-x{position:absolute;top:12px;right:14px;background:none;border:none;font-size:26px;line-height:1;color:var(--muted);cursor:pointer;padding:4px 8px}
  .gate-x:hover{color:var(--ink)}
  .gate-eyebrow{font-family:"Montserrat",sans-serif;font-size:10.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin:0 0 8px}
  .gate-title{font-family:"Playfair Display",Georgia,serif;font-weight:600;font-size:25px;line-height:1.12;color:var(--navy);margin:0 0 10px}
  .gate-copy{font-size:13.5px;line-height:1.55;color:var(--muted);margin:0 0 18px}
  .gate-widget{text-align:left;margin:0 0 14px;min-height:40px}
  .gate-fallback{text-align:center}
  .gate-cta{display:inline-flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;background:var(--navy);color:#fff;font-family:"Montserrat",sans-serif;font-weight:600;font-size:12.5px;letter-spacing:.04em;text-transform:uppercase;padding:13px 20px;border-radius:11px}
  .gate-note{font-size:11px;color:var(--muted);margin:10px 0 0}
  .gate-continue{display:block;width:100%;background:none;border:none;cursor:pointer;color:var(--blue-deep);font-family:"Montserrat",sans-serif;font-weight:600;font-size:12px;letter-spacing:.03em;padding:8px;margin-top:2px}
  .gate-continue:hover{text-decoration:underline}
  .gate-fine{font-size:10.5px;color:var(--muted);margin:10px 0 0}
  .gate-form{display:flex;flex-direction:column;gap:9px}
  .gate-hp{position:absolute!important;left:-9999px;width:1px;height:1px;opacity:0}
  .gate-row{display:flex;gap:9px}
  .gate-row input{flex:1;min-width:0}
  .gate-form input{width:100%;font-family:inherit;font-size:14px;color:var(--ink);padding:11px 13px;border:1px solid var(--line);border-radius:10px;background:var(--cream);outline:none;-webkit-appearance:none;transition:border-color .14s ease,box-shadow .14s ease}
  .gate-form input::placeholder{color:var(--muted)}
  .gate-form input:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(197,165,90,.20)}
  .gate-form .gate-cta{width:100%;border:none;cursor:pointer;margin-top:3px}
  .gate-form .gate-cta:disabled{opacity:.6;cursor:default}
  .gate-err{color:#b3261e;font-size:12px;margin:2px 0 0}
  /* ===== Pin hero photo gallery (swipe) ===== */
  .gallery{margin:2px 0 16px;position:relative}
  .gallery-track{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;border-radius:12px;scrollbar-width:none;box-shadow:0 6px 18px -10px rgba(10,42,64,.5)}
  .gallery-track::-webkit-scrollbar{display:none}
  .gphoto{flex:0 0 100%;width:100%;height:210px;object-fit:cover;scroll-snap-align:center;display:block;background:var(--sand)}
  .gallery-dots{display:flex;justify-content:center;gap:6px;margin-top:9px}
  .gdot{width:6px;height:6px;border-radius:50%;background:var(--line);transition:background .2s ease,transform .2s ease}
  .gdot.on{background:var(--gold);transform:scale(1.25)}
  .gcredit{font-size:10px;color:var(--muted);text-align:right;margin:5px 2px 0}
</style>
</head>
<body>

<header class="bar">
  <a class="brand" href="https://adamsonfl.com/" title="Back to AdamsonFL.com — Ryan Adamson, PA">
    <img class="logo" src="/images/logos/adamson-group-black.png" alt="Adamson Group" width="44" height="44" />
    <div class="lockup">
      <div class="gname">Sarasota Area Guide</div>
      <div class="tag">Curated by Ryan Adamson, PA</div>
    </div>
  </a>
  <a class="home-link" href="https://adamsonfl.com/" aria-label="Back to AdamsonFL.com">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9.5 12 3l9 6.5"/><path d="M5 10v10h14V10"/></svg>
    <span>AdamsonFL.com</span>
  </a>
  <a class="call" href={`tel:${tel}`}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    <span class="num">{phone}</span>
  </a>
</header>

<div id="map"></div>

<aside class="rail collapsed" id="rail">
  <div class="handle" id="handle"><div class="bar-grip"></div></div>
  <div id="listView" style="display:flex;flex-direction:column;overflow:hidden">
    <div class="rail-head">
      <p class="rail-eyebrow">Local intel from your agent</p>
      <h1 class="rail-title">Explore Sarasota &amp; the Keys</h1>
      <p class="rail-sub"><b id="count">0 places</b> · <span id="subnote">curated by <a class="subnote-link" href="https://adamsonfl.com/">Ryan Adamson, PA</a></span></p>
    </div>
    <div class="search">
      <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input id="q" type="search" inputmode="search" autocomplete="off" placeholder="Search places, food, vibes…" aria-label="Search the guide" />
    </div>
    <div class="chips" id="chips"></div>
    <div class="list" id="list"></div>
  </div>
  <div class="detail" id="detailView">
    <button class="back" id="back">‹ Back to all places</button>
    <div class="detail-body" id="detailBody"></div>
  </div>
</aside>

<!-- Crawlable content for search engines & AI answer engines -->
<div class="visually-hidden">
  <h2>Sarasota &amp; the Keys local directory — curated by Ryan Adamson, PA</h2>
  {GROUPS.map((g) => (
    <section>
      <h3>{g.label}</h3>
      {pins.filter((p) => p.group === g.id).map((p) => (
        <article>
          <h4>{p.name}</h4>
          {p.address && <p>{p.address}</p>}
          {p.blurb && <p>{p.blurb}</p>}
          {p.tip && <p>Ryan's take: {p.tip}</p>}
          {p.website && <a href={p.website}>{p.name} website</a>}
        </article>
      ))}
    </section>
  ))}
</div>

<!-- Soft lead-capture gate (client-side only — crawlers/AI engines never see this; full content stays in the SSR block above) -->
<div class="gate" id="gate" aria-hidden="true">
  <div class="gate-card" role="dialog" aria-modal="true" aria-labelledby="gateTitle">
    <button class="gate-x" id="gateClose" type="button" aria-label="Close">&times;</button>
    <p class="gate-eyebrow">Unlock the full guide</p>
    <h2 class="gate-title" id="gateTitle">See every spot Ryan recommends</h2>
    <p class="gate-copy">You&rsquo;ve been exploring Sarasota &amp; the Keys. Create a free account to keep opening places &mdash; and save searches, get new-listing alerts, and Ryan&rsquo;s local picks.</p>
    <div class="gate-widget" id="gateWidget">
      <form class="gate-form" id="gateForm" novalidate>
        <input type="text" name="bot-field" class="gate-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="gate-row">
          <input type="text" id="gf_first" name="first_name" placeholder="First name" autocomplete="given-name" required />
          <input type="text" id="gf_last" name="last_name" placeholder="Last name" autocomplete="family-name" />
        </div>
        <input type="email" id="gf_email" name="email" placeholder="Email address" autocomplete="email" required />
        <input type="tel" id="gf_phone" name="phone" placeholder="Phone (optional)" autocomplete="tel" />
        <button type="submit" class="gate-cta" id="gfSubmit">Unlock the full guide</button>
        <p class="gate-err" id="gfErr" hidden></p>
      </form>
    </div>
    <p class="gate-fine">No spam. Your details go straight to Ryan Adamson, PA &middot; saved to the Adamson Group.</p>
  </div>
</div>

<script type="application/json" id="pins-data" set:html={JSON.stringify(pins)}></script>
<script type="application/json" id="groups-data" set:html={JSON.stringify(GROUPS)}></script>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script is:inline>
(function(){
  var PLACES = JSON.parse(document.getElementById('pins-data').textContent);
  var GROUPS = JSON.parse(document.getElementById('groups-data').textContent);
  var GMAP = {}; GROUPS.forEach(function(g){ GMAP[g.id]=g; });
  PLACES.forEach(function(p,i){ p._id = i; p._hay = (p.name+' '+(p.blurb||'')+' '+(p.address||'')+' '+(p.tip||'')+' '+(p.vibe||'')+' '+(p.good_for||'')+' '+(p.price||'')+' '+((GMAP[p.group]||{}).label||'')).toLowerCase(); });

  var TEL = '19417139234', PHONE = '(941) 713-9234';
  function iconSvg(g, cls){ return '<svg class="'+(cls||'')+'" viewBox="0 0 24 24">'+GMAP[g].svg+'</svg>'; }
  function esc(s){ return (s==null?'':String(s)).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  var active = {}; GROUPS.forEach(function(g){ active[g.id]=true; });
  var selectedId = null, markers = {}, query = '';

  // ===== Soft lead gate — AEO-safe: only gates the interactive detail panel, never the SSR content =====
  var GATE_ENABLED = false;           // TEMP 2026-07-05: login wall OFF for testing — set back to true to re-enable
  var GATE_FREE_OPENS = 3;            // distinct pins a visitor may open before the signup nudge
  var GATE_OPENED_KEY = 'srqmap_opened_v1';
  var GATE_UNLOCK_KEY = 'srqmap_unlocked_v1';
  var gatePendingId = null;
  function gateStore(){ try { return window.localStorage; } catch(e){ return null; } }
  function gateUnlocked(){ var s=gateStore(); return !!(s && s.getItem(GATE_UNLOCK_KEY)==='1'); }
  function gateOpened(){ var s=gateStore(); if(!s) return []; try{ return JSON.parse(s.getItem(GATE_OPENED_KEY)||'[]'); }catch(e){ return []; } }
  function gateRecord(id){ var s=gateStore(); if(!s) return; var a=gateOpened(); if(a.indexOf(id)<0){ a.push(id); try{ s.setItem(GATE_OPENED_KEY, JSON.stringify(a)); }catch(e){} } }
  function gateUnlock(){ var s=gateStore(); if(s){ try{ s.setItem(GATE_UNLOCK_KEY,'1'); }catch(e){} } }
  function gateAllows(id){ if(!GATE_ENABLED) return true; if(gateUnlocked()) return true; var a=gateOpened(); if(a.indexOf(id)>=0) return true; return a.length < GATE_FREE_OPENS; }
  var gateEl=document.getElementById('gate');
  function openGate(){ if(gateEl){ gateEl.classList.add('show'); gateEl.setAttribute('aria-hidden','false'); } }
  function closeGate(){ if(gateEl){ gateEl.classList.remove('show'); gateEl.setAttribute('aria-hidden','true'); } }
  (function(){
    if(!gateEl) return;
    var x=document.getElementById('gateClose'); if(x) x.onclick=closeGate;
    function onUnlocked(){ closeGate(); if(gatePendingId!=null){ var id=gatePendingId; gatePendingId=null; select(id, false); } }
    var gForm=document.getElementById('gateForm');
    if(gForm){
      var errEl=document.getElementById('gfErr'), btn=document.getElementById('gfSubmit');
      var showErr=function(m){ if(errEl){ errEl.textContent=m; errEl.hidden=false; } };
      gForm.addEventListener('submit', function(e){
        e.preventDefault();
        var first=(document.getElementById('gf_first').value||'').trim();
        var last=(document.getElementById('gf_last').value||'').trim();
        var email=(document.getElementById('gf_email').value||'').trim();
        var phone=(document.getElementById('gf_phone').value||'').trim();
        var hp=(gForm.querySelector('[name="bot-field"]')||{}).value||'';
        if(!first){ showErr('Please enter your first name.'); return; }
        if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){ showErr('Please enter a valid email address.'); return; }
        if(errEl) errEl.hidden=true;
        var label=btn?btn.textContent:''; if(btn){ btn.disabled=true; btn.textContent='Saving\u2026'; }
        fetch('/.netlify/functions/srqmap-lead',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({first_name:first,last_name:last,email:email,phone:phone,'bot-field':hp,source:'srqmap-gate'})})
          .then(function(r){ return r.ok ? r.json() : r.json().then(function(j){ throw new Error((j&&j.error)||'error'); }); })
          .then(function(){ gateUnlock(); onUnlocked(); })
          .catch(function(){ if(btn){ btn.disabled=false; btn.textContent=label; } showErr('Something went wrong — please try again, or call Ryan at '+PHONE+'.'); });
      });
    }
    gateEl.addEventListener('click', function(e){ if(e.target===gateEl) closeGate(); });
    document.addEventListener('keydown', function(e){ if(e.key!=='Escape') return; if(gateEl && gateEl.classList.contains('show')){ closeGate(); return; } if(detailView && detailView.classList.contains('show')){ hideDetail(); selectedId=null; refresh(); } });
  })();

  // Initial view: centered on 301 Bird Key Dr, framing Lido Key + mid-Siesta and up
  var HOME_CENTER = [27.3145, -82.5610], HOME_ZOOM = 13;
  var map = L.map('map',{zoomControl:false, attributionControl:true}).setView(HOME_CENTER, HOME_ZOOM);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',{
    subdomains:'abcd', maxZoom:20,
    attribution:'&copy; <a href="https://openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>'
  }).addTo(map);
  L.control.zoom({position:'bottomright'}).addTo(map);
  // ---- Locate me (browser geolocation) ----
  var userLatLng = null, youMarker = null, youCircle = null, locateBtn = null;
  var LocateControl = L.Control.extend({
    options:{position:'bottomright'},
    onAdd:function(){
      var wrap = L.DomUtil.create('div','leaflet-bar leaflet-control locate-ctl');
      var b = L.DomUtil.create('button','locate-btn', wrap);
      b.type='button'; b.title='Show my location'; b.setAttribute('aria-label','Show my location');
      b.innerHTML='<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="7"/><line x1="12" y1="1" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="23"/><line x1="1" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="23" y2="12"/><circle cx="12" cy="12" r="2.4" fill="currentColor" stroke="none"/></svg>';
      L.DomEvent.disableClickPropagation(wrap);
      L.DomEvent.on(b,'click', function(e){ L.DomEvent.stop(e); locateMe(); });
      locateBtn = b;
      return wrap;
    }
  });
  map.addControl(new LocateControl());

  function locateMe(){
    if(!('geolocation' in navigator)){ alert('Location isn’t supported by this browser.'); return; }
    if(locateBtn){ locateBtn.classList.remove('active'); locateBtn.classList.add('locating'); }
    map.locate({setView:true, enableHighAccuracy:true, maxZoom:15, timeout:10000});
  }
  map.on('locationfound', function(e){
    userLatLng = e.latlng;
    if(locateBtn){ locateBtn.classList.remove('locating'); locateBtn.classList.add('active'); }
    var html='<div class="you-dot"><div class="ring"></div><div class="core"></div></div>';
    var icon=L.divIcon({html:html, className:'', iconSize:[18,18], iconAnchor:[9,9]});
    if(youMarker){ youMarker.setLatLng(e.latlng); } else { youMarker=L.marker(e.latlng,{icon:icon, interactive:false, keyboard:false, zIndexOffset:1000}).addTo(map); }
    var r = Math.min(Math.max(e.accuracy||0, 20), 1200);
    if(youCircle){ youCircle.setLatLng(e.latlng).setRadius(r); } else { youCircle=L.circle(e.latlng,{radius:r, color:'#2E86AB', weight:1, fillColor:'#2E86AB', fillOpacity:.10, interactive:false}).addTo(map); }
    if(selectedId!=null){ var p=PLACES[selectedId]; if(p) showDetail(p); }
  });
  map.on('locationerror', function(){
    if(locateBtn){ locateBtn.classList.remove('locating'); }
    alert('Couldn’t get your location. Please allow location access for this site in your browser, then tap the locate button again.');
  });

  function directionsUrl(p){
    var dest = p.address ? encodeURIComponent(p.address) : (p.lat+','+p.lng);
    var origin = userLatLng ? ('&origin='+userLatLng.lat+','+userLatLng.lng) : '';
    return 'https://www.google.com/maps/dir/?api=1'+origin+'&destination='+dest+'&travelmode=driving';
  }

  function fit(){ map.invalidateSize(); map.setView(HOME_CENTER, HOME_ZOOM); }
  fit();
  setTimeout(fit, 300);
  window.addEventListener('load', fit);

  function buildMarkers(){
    PLACES.forEach(function(p){
      var c = GMAP[p.group].color;
      var html = '<div class="pin-marker" style="--c:'+c+'"><div class="body">'+iconSvg(p.group)+'</div></div>';
      var icon = L.divIcon({html:html, iconSize:[30,30], iconAnchor:[15,30]});
      var m = L.marker([p.lat,p.lng],{icon:icon}).addTo(map);
      m.on('click', function(){ select(p._id, true); });
      markers[p._id] = {marker:m, place:p};
    });
  }
  buildMarkers();

  var chipsEl = document.getElementById('chips');
  function renderChips(){
    chipsEl.innerHTML='';
    GROUPS.forEach(function(g){
      var b=document.createElement('button');
      b.className='chip'; b.style.setProperty('--c', g.color);
      b.setAttribute('aria-pressed', active[g.id]);
      b.innerHTML='<span class="dot"></span>'+esc(g.label);
      b.onclick=function(){ active[g.id]=!active[g.id]; refresh(); };
      chipsEl.appendChild(b);
    });
  }

  var listEl=document.getElementById('list');
  var countEl=document.getElementById('count');
  function matchesQuery(p){ if(!query) return true; return query.split(/\s+/).every(function(t){ return p._hay.indexOf(t)>=0; }); }
  function isVisible(p){ return active[p.group] && matchesQuery(p); }
  function visible(){ return PLACES.filter(isVisible); }
  function renderList(){
    var items=visible();
    countEl.textContent=items.length+(items.length===1?' place':' places');
    listEl.innerHTML='';
    if(items.length===0){ listEl.innerHTML='<div class="empty">No matches'+(query?' for \u201c'+esc(query)+'\u201d':'')+'.<br>Try another word or clear the search.</div>'; return; }
    items.forEach(function(p){
      var g=GMAP[p.group];
      var card=document.createElement('div');
      card.className='card'+(p._id===selectedId?' active':'');
      card.style.setProperty('--c', g.color);
      card.innerHTML='<div class="marker">'+iconSvg(p.group)+'</div><div><h3>'+esc(p.name)+'</h3><div class="meta"><span class="cat-label" style="color:'+g.color+'">'+esc(g.label)+'</span></div></div>';
      card.onclick=function(){ select(p._id, true); };
      listEl.appendChild(card);
    });
  }
  function refreshMarkers(){
    Object.keys(markers).forEach(function(k){
      var mk=markers[k], on=isVisible(mk.place);
      if(on && !map.hasLayer(mk.marker)) mk.marker.addTo(map);
      if(!on && map.hasLayer(mk.marker)) map.removeLayer(mk.marker);
      var el=mk.marker.getElement();
      if(el){ var pm=el.querySelector('.pin-marker'); if(pm) pm.classList.toggle('active', mk.place._id===selectedId); }
    });
  }
  function refresh(){ renderChips(); renderList(); refreshMarkers(); }

  var listView=document.getElementById('listView');
  var detailView=document.getElementById('detailView');
  var detailBody=document.getElementById('detailBody');
  function showDetail(p){
    var g=GMAP[p.group];
    detailBody.style.setProperty('--c', g.color);
    var facts=[];
    if(p.price) facts.push(esc(p.price));
    if(p.vibe) facts.push(esc(p.vibe));
    if(p.good_for) facts.push(esc(p.good_for));
    var factsHtml = facts.length ? '<div class="facts">'+facts.map(function(f){return '<span class="fact">'+f+'</span>';}).join('')+'</div>' : '';
    var blurbHtml = p.blurb ? '<p class="blurb">'+esc(p.blurb)+'</p>' : '';
    var tipHtml = p.tip ? '<div class="tip"><p class="tip-h">Ryan’s take</p><p>'+esc(p.tip)+'</p></div>' : '';
    var siteHtml = p.website ? '<a class="detail-link" href="'+esc(p.website)+'" target="_blank" rel="noopener">Visit website</a>' : '';
    var marketHtml = p.market ? '<a class="detail-link" href="'+esc(p.market)+'" target="_blank" rel="noopener">Live market data for this area</a>' : '';
    var dirHtml = '<a class="detail-link" href="'+directionsUrl(p)+'" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>'+(userLatLng?'Directions from my location':'Get directions')+'</a>';
    var photos = Array.isArray(p.photos) ? p.photos.filter(Boolean) : [];
    var galleryHtml = '';
    if(photos.length){
      /* no loading="lazy" here: the gallery is built inside a hidden panel, and Chrome never
         promotes lazy images created in display:none subtrees — they'd stay blank forever. */
      var slides = photos.map(function(src,idx){ return '<img class="gphoto" src="'+esc(src)+'" decoding="async" alt="'+esc(p.name)+'" />'; }).join('');
      var gdotsHtml = photos.length>1 ? '<div class="gallery-dots">'+photos.map(function(_x,idx){return '<span class="gdot'+(idx===0?' on':'')+'"></span>';}).join('')+'</div>' : '';
      var gcreditHtml = p.photo_credit ? '<p class="gcredit">'+esc(p.photo_credit)+'</p>' : '';
      galleryHtml = '<div class="gallery"><div class="gallery-track">'+slides+'</div>'+gdotsHtml+gcreditHtml+'</div>';
    }
    detailBody.innerHTML =
      galleryHtml +
      '<div class="kicker"><span class="pin"></span>'+esc(g.label)+'</div>'+
      '<h2>'+esc(p.name)+'</h2>'+
      (p.address?'<p class="addr">'+esc(p.address)+'</p>':'')+
      factsHtml + blurbHtml + tipHtml +
      '<div class="links"><a class="detail-cta" href="tel:'+TEL+'">Ask Ryan about this</a>'+dirHtml+siteHtml+marketHtml+'</div>'+
      '<p class="signoff">Ryan Adamson, PA · <a href="https://adamsonfl.com/" style="color:var(--blue-deep);font-weight:600;text-decoration:none">AdamsonFL.com</a></p>';
    var gtrack = detailBody.querySelector('.gallery-track');
    if(gtrack){ var gd = detailBody.querySelectorAll('.gdot'); if(gd.length){ gtrack.addEventListener('scroll', function(){ var gi=Math.round(gtrack.scrollLeft/Math.max(gtrack.clientWidth,1)); for(var k=0;k<gd.length;k++){ gd[k].classList.toggle('on', k===gi); } }, {passive:true}); } }
    listView.style.display='none';
    detailView.classList.add('show');
    detailView.scrollTop=0;
  }
  function hideDetail(){ detailView.classList.remove('show'); listView.style.display='flex'; }
  document.getElementById('back').onclick=function(){ hideDetail(); selectedId=null; refresh(); };
  // Clicking empty map = intuitive exit from a pin detail back to the full list
  map.on('click', function(){ if(detailView.classList.contains('show')){ hideDetail(); selectedId=null; refresh(); } });

  function select(id, fly){
    if(!gateAllows(id)){
      gatePendingId=id;
      if(fly){ var gp=PLACES[id]; if(gp) map.flyTo([gp.lat,gp.lng], Math.max(map.getZoom(),15), {duration:.8}); }
      openGate(); return;
    }
    gateRecord(id);
    selectedId=id;
    var p=PLACES[id]; if(!p) return;
    if(!active[p.group]){ active[p.group]=true; }
    document.getElementById('rail').classList.remove('collapsed');
    refresh(); showDetail(p);
    if(fly) map.flyTo([p.lat,p.lng], Math.max(map.getZoom(),15), {duration:.8});
  }

  // ---- free-text search wiring ----
  var qEl=document.getElementById('q');
  function fitVisible(){ var vs=visible(); if(query && vs.length){ var b=L.latLngBounds(vs.map(function(p){return [p.lat,p.lng];})); if(b.isValid()) map.fitBounds(b,{padding:[60,60], maxZoom:15}); } }
  if(qEl){ qEl.addEventListener('input', function(){ query=qEl.value.trim().toLowerCase(); selectedId=null; refresh(); fitVisible(); }); }

  // ---- mobile: drag the bottom sheet up/down (not just tap) ----
  (function(){
    var rail=document.getElementById('rail'), handle=document.getElementById('handle'), head=document.querySelector('.rail-head');
    function isMobile(){ return window.matchMedia('(max-width:720px)').matches; }
    function collapsedT(){ return Math.max(rail.offsetHeight - 152, 0); }
    var dragging=false, startY=0, startT=0, curT=0, maxT=0, moved=false, suppress=false;
    function pointY(e){ return (e.touches && e.touches[0]) ? e.touches[0].clientY : e.clientY; }
    function start(e){
      if(!isMobile()) return;
      if(e.target.closest('input, button, a, .chip, .search')) return;
      dragging=true; moved=false; maxT=collapsedT();
      startT = rail.classList.contains('collapsed') ? maxT : 0;
      startY = pointY(e); rail.style.transition='none';
    }
    function move(e){
      if(!dragging) return;
      var dy = pointY(e) - startY;
      if(Math.abs(dy) > 5) moved=true;
      curT = Math.min(Math.max(startT + dy, 0), maxT);
      rail.style.transform = 'translateY('+curT+'px)';
      if(e.cancelable && moved) e.preventDefault();
    }
    function end(){
      if(!dragging) return;
      dragging=false; rail.style.transition=''; rail.style.transform='';
      if(moved){ suppress=true; if(curT > maxT*0.45){ rail.classList.add('collapsed'); } else { rail.classList.remove('collapsed'); } }
    }
    [handle, head].forEach(function(el){ if(!el) return;
      el.addEventListener('touchstart', start, {passive:true});
      el.addEventListener('mousedown', start);
    });
    window.addEventListener('touchmove', move, {passive:false});
    window.addEventListener('mousemove', move);
    window.addEventListener('touchend', end);
    window.addEventListener('mouseup', end);
    function toggle(){ if(suppress){ suppress=false; return; } rail.classList.toggle('collapsed'); }
    if(handle) handle.addEventListener('click', toggle);
  })();
  refresh();
})();
</script>
</body>
</html>

          <div class="flex flex-wrap gap-3 mt-6">
            <span class="gbc-chip">Gulf-Front</span>
            <span class="gbc-chip">Siesta Key Beach</span>
            <span class="gbc-chip">Tennis &amp; Pools</span>
            <span class="gbc-chip">Gated</span>
            <span class="gbc-chip">Bayside Boating</span>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3 lg:gap-4">
          <figure class="gbc-fig gbc-fig-tall"><img src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/aa/Siesta_Key_Beach._Sarasota_-_panoramio.jpg/1920px-Siesta_Key_Beach._Sarasota_-_panoramio.jpg" alt="Siesta Key Beach near Gulf & Bay Club" loading="lazy" /></figure>

---
import BaseLayout from '@/layouts/BaseLayout.astro';

const description = 'Contact Ryan Adamson for luxury real estate inquiries in Sarasota, Longboat Key, Lido Key, Siesta Key, and the barrier islands. Schedule a consultation today.';

const jsonLd = {
  '@type': 'ContactPage',
  name: 'Contact Ryan Adamson',
  description: description,
  url: 'https://adamsonfl.com/contact',
};
---

<BaseLayout title="Contact" description={description} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="relative pt-32 pb-20">
    <div class="absolute inset-0" style="background-color: var(--color-navy);" />
    <div class="relative z-10 container text-center">
      <p class="font-accent text-xs uppercase tracking-[0.3em] text-[var(--color-gold)] mb-3">
        Let's Connect
      </p>
      <h1 class="font-display text-white mb-4">Get in Touch</h1>
      <p class="text-lg text-white/70 max-w-xl mx-auto">
        Whether you're buying, selling, or exploring the market — I'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section bg-white">
    <div class="container-narrow">
      <form
        name="contact"
        method="POST"
        action="/thank-you"
        netlify
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-6"
      >
        <!-- Hidden form-name field — required by Netlify when using JS-based form submissions or custom action -->
        <input type="hidden" name="form-name" value="contact" />

        <!-- Honeypot — invisible field that real users won't fill in. Bots usually do, and Netlify rejects those. -->
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block font-accent text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
              Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-gold)] transition-colors bg-[var(--color-warm-white)]"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block font-accent text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-gold)] transition-colors bg-[var(--color-warm-white)]"
              placeholder="your@email.com"
            />
          </div>
        </div>

        <div>
          <label for="phone" class="block font-accent text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
            Phone <span class="normal-case tracking-normal text-[var(--color-text-light)]">(optional)</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-gold)] transition-colors bg-[var(--color-warm-white)]"
            placeholder="(941) 555-0000"
          />
        </div>

        <div>
          <label for="interest" class="block font-accent text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
            I'm Interested In
          </label>
          <select
            id="interest"
            name="interest"
            class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-gold)] transition-colors bg-[var(--color-warm-white)]"
          >
            <option value="">Select an option</option>
            <option value="buying">Buying a Home</option>
            <option value="selling">Selling a Home</option>
            <option value="market-info">Market Information</option>
            <option value="relocation">Relocating to Sarasota</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block font-accent text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-gold)] transition-colors bg-[var(--color-warm-white)] resize-vertical"
            placeholder="Tell me about what you're looking for..."
          ></textarea>
        </div>

        <!-- Netlify-managed reCAPTCHA v2 ("I'm not a robot" checkbox).
             The attribute on a child div (NOT on the <form> tag) is the correct
             placement — Netlify replaces this div with the widget at deploy time
             using its own managed Google keys. -->
        <div class="flex justify-center pt-2">
          <div data-netlify-recaptcha="true"></div>
        </div>

        <div class="text-center pt-2">
          <button
            type="submit"
            class="inline-flex items-center justify-center font-accent text-xs uppercase tracking-wider px-10 py-4 bg-[var(--color-gold)] text-[var(--color-navy)] hover:bg-[var(--color-gold-light)] font-semibold rounded transition-all duration-200"
          >
            Send Message
          </button>
          <p id="contact-status" class="text-sm mt-4 min-h-[1.25rem] text-[var(--color-text-muted)]" role="status" aria-live="polite"></p>
        </div>
      </form>

      <!-- On-brand confirmation — swapped in for the form on successful submit,
           so the visitor stays right here instead of bouncing to a generic page. -->
      <div id="contact-done" hidden class="text-center py-10">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-[var(--color-gold)]/40 bg-[var(--color-gold)]/10">
          <svg class="h-7 w-7 text-[var(--color-gold)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <p class="font-accent text-xs uppercase tracking-[0.3em] text-[var(--color-gold)] mb-3">Message Received</p>
        <h2 class="font-display text-3xl sm:text-4xl mb-4" style="color: var(--color-navy);">Thank You<span id="contact-done-name"></span></h2>
        <p class="text-lg text-[var(--color-text-muted)] max-w-xl mx-auto leading-relaxed">
          Your message has reached Ryan directly. He personally reviews every inquiry
          and will be in touch within one business day.
        </p>
        <p class="mt-6 text-sm text-[var(--color-text-muted)]">
          Prefer to talk sooner?
          <a href="tel:+19417139234" class="text-[var(--color-gold)] hover:text-[var(--color-gold-light)] transition-colors whitespace-nowrap font-semibold">(941) 713-9234</a>
        </p>
      </div>
    </div>
  </section>

  <script>
    // Submit in place: the visitor never leaves /contact, so there is no
    // generic interstitial and no way to get lost. action="/thank-you" above
    // remains as the no-JS fallback.
    const form = document.querySelector('form[name="contact"]');
    const statusEl = document.getElementById('contact-status');
    const done = document.getElementById('contact-done');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      if (fd.get('bot-field')) return; // honeypot

      const btn = form.querySelector('button[type=submit]');
      statusEl.textContent = 'Sending…';
      btn.disabled = true;

      try {
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(fd as any).toString(),
        });
        if (!res.ok) throw new Error('status ' + res.status);

        const first = String(fd.get('name') || '').trim().split(/\s+/)[0].replace(/[<>&"']/g, '');
        const nameEl = document.getElementById('contact-done-name');
        if (first && nameEl) nameEl.textContent = ', ' + first;
        form.hidden = true;
        done.hidden = false;
        done.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        console.error(err);
        statusEl.textContent =
          'Something didn’t go through — please check the reCAPTCHA box and try again, or call (941) 713-9234.';
        btn.disabled = false;
      }
    });
  </script>

</BaseLayout>
